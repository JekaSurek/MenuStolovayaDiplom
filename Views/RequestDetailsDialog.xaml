<Window x:Class="MenuStolovaya.Views.RequestDetailsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Детали требования" 
        Height="550" 
        Width="900"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BackgroundBrush}">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <TextBlock Grid.Row="0" 
                   x:Name="TitleText"
                   Style="{StaticResource SubtitleStyle}"
                   Margin="0,0,0,15"/>

        <!-- Информация о требовании -->
        <Border Grid.Row="1" 
                Style="{StaticResource CardStyle}">
            <Grid Margin="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Номер:" FontWeight="SemiBold"/>
                <TextBlock Grid.Row="0" Grid.Column="1" x:Name="NumberText"/>
                <TextBlock Grid.Row="0" Grid.Column="2" Text="Дата:" FontWeight="SemiBold"/>
                <TextBlock Grid.Row="0" Grid.Column="3" x:Name="DateText"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="Технолог:" FontWeight="SemiBold"/>
                <TextBlock Grid.Row="1" Grid.Column="1" x:Name="TechnologistText"/>
                <TextBlock Grid.Row="1" Grid.Column="2" Text="Статус:" FontWeight="SemiBold"/>
                <TextBlock Grid.Row="1" Grid.Column="3" x:Name="StatusText"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="Комментарий:" FontWeight="SemiBold"/>
                <TextBlock Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="3" x:Name="CommentText" TextWrapping="Wrap"/>
            </Grid>
        </Border>

        <!-- Таблица продуктов -->
        <Border Grid.Row="2" 
                Style="{StaticResource CardStyle}" 
                Margin="0,10,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" 
                           Text="Состав требования" 
                           FontWeight="SemiBold"
                           Margin="5,5,0,5"/>

                <DataGrid x:Name="ProductsGrid" 
                          Grid.Row="1"
                          AutoGenerateColumns="False"
                          IsReadOnly="True">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Артикул" Binding="{Binding Артикул}" Width="100"/>
                        <DataGridTextColumn Header="Продукт" Binding="{Binding Продукт}" Width="250"/>
                        <DataGridTextColumn Header="Ед. изм." Binding="{Binding Единица_измерения}" Width="80"/>
                        <DataGridTextColumn Header="Количество" Binding="{Binding Количество, StringFormat={}{0:F3}}" Width="120"/>
                        <DataGridTextColumn Header="Цена" Binding="{Binding Цена, StringFormat={}{0:N2} руб.}" Width="120"/>
                        <DataGridTextColumn Header="Сумма" Binding="{Binding Сумма, StringFormat={}{0:N2} руб.}" Width="120"/>
                        <DataGridTextColumn Header="Остаток на складе" Binding="{Binding Остаток_на_складе, StringFormat={}{0:F3}}" Width="130"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <!-- Кнопки -->
        <Border Grid.Row="3" 
                Style="{StaticResource CardStyle}" 
                Margin="0,15,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Печать" 
                        Style="{StaticResource PrimaryButtonStyle}"
                        Width="100"
                        Click="PrintButton_Click"
                        Margin="5"/>
                <Button Content="Закрыть" 
                        Style="{StaticResource PrimaryButtonStyle}"
                        Background="{StaticResource AccentDarkBrush}"
                        Width="100"
                        Click="CloseButton_Click"
                        Margin="5"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>