<Window x:Class="MenuStolovaya.Views.EditMenuItemWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Редактирование блюда в меню" 
        Height="400" 
        Width="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Window.Resources>
        <Style TargetType="TextBox">
            <Setter Property="Height" Value="30"/>
            <Setter Property="Margin" Value="10,5,10,10"/>
            <Setter Property="Padding" Value="5"/>
        </Style>

        <Style TargetType="TextBlock">
            <Setter Property="Margin" Value="10,10,10,5"/>
            <Setter Property="Foreground" Value="#FF333333"/>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Height" Value="35"/>
            <Setter Property="Width" Value="100"/>
            <Setter Property="Margin" Value="10"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Форма -->
        <Border Grid.Row="0" Background="White" Margin="10" Padding="10">
            <StackPanel>
                <TextBlock Text="Редактирование блюда в меню" 
                           FontSize="16" 
                           FontWeight="Bold" 
                           HorizontalAlignment="Center" 
                           Margin="0,0,0,20"/>

                <TextBlock Text="Блюдо:"/>
                <TextBlock x:Name="DishNameText" 
                           FontWeight="Bold"
                           Margin="10,5,10,10"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,5,0">
                        <TextBlock Text="Количество порций:"/>
                        <TextBox x:Name="PortionsTextBox" 
                                 PreviewTextInput="NumberValidationTextBox"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="5,0,0,0">
                        <TextBlock Text="Выход на порцию (г):"/>
                        <TextBox x:Name="OutputTextBox"/>
                    </StackPanel>
                </Grid>

                <TextBlock Text="Время подачи:"/>
                <ComboBox x:Name="TimeComboBox" 
                          SelectedIndex="0"
                          Height="30" 
                          Margin="0,5,0,10">
                    <ComboBoxItem Content="Обед"/>
                    <ComboBoxItem Content="Ужин"/>
                    <ComboBoxItem Content="Завтрак"/>
                    <ComboBoxItem Content="Полдник"/>
                </ComboBox>
            </StackPanel>
        </Border>

        <!-- Кнопки -->
        <Border Grid.Row="1" Background="#FFEEEEEE" Padding="10">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Сохранить" 
                        Background="#FF4CAF50" 
                        Foreground="White"
                        Click="SaveButton_Click"
                        IsDefault="True"/>
                <Button Content="Отмена" 
                        Background="#FF9E9E9E" 
                        Foreground="White"
                        Click="CancelButton_Click"
                        IsCancel="True"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>