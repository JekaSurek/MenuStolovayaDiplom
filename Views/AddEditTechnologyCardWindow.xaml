<Window x:Class="MenuStolovaya.Views.AddEditTechnologyCardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="{Binding WindowTitle}" 
        Height="600" 
        Width="800"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">

    <Window.Resources>
        <Style TargetType="TextBox">
            <Setter Property="Height" Value="30"/>
            <Setter Property="Margin" Value="10,5,10,10"/>
            <Setter Property="Padding" Value="5"/>
        </Style>

        <Style TargetType="TextBlock">
            <Setter Property="Margin" Value="10,10,10,5"/>
            <Setter Property="Foreground" Value="#FF333333"/>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Height" Value="30"/>
            <Setter Property="Margin" Value="10,5,10,10"/>
            <Setter Property="Padding" Value="5"/>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Height" Value="35"/>
            <Setter Property="Width" Value="100"/>
            <Setter Property="Margin" Value="10"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Форма -->
        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
            <Border Background="White" Margin="10" Padding="10">
                <StackPanel>
                    <TextBlock Text="{Binding WindowTitle}" 
                               FontSize="18" 
                               FontWeight="Bold" 
                               HorizontalAlignment="Center" 
                               Margin="0,0,0,20"/>

                    <TextBlock Text="Номер карты:"/>
                    <TextBox Text="{Binding Card.Номер, UpdateSourceTrigger=PropertyChanged}"
                             IsReadOnly="True"
                             Foreground="Gray"/>

                    <TextBlock Text="Блюдо:"/>
                    <ComboBox x:Name="DishComboBox" 
                              DisplayMemberPath="Наименование"
                              SelectedValuePath="Id"
                              SelectedValue="{Binding SelectedDishId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                              IsEnabled="{Binding IsNewCard}"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Margin="0,0,5,0">
                            <TextBlock Text="Выход (г):"/>
                            <TextBox x:Name="OutputTextBox"
                                     Text="{Binding Card.Выход, UpdateSourceTrigger=PropertyChanged, StringFormat=N1}"
                                     PreviewTextInput="NumberValidationTextBox"/>
                            <TextBlock Text="Стандартный выход блюда:"
                                       FontSize="11"
                                       Foreground="Gray"
                                       Margin="10,0,10,0"/>
                            <TextBlock x:Name="StandardOutputText"
                                       Text="0 г"
                                       FontSize="11"
                                       Foreground="Green"
                                       FontWeight="Bold"
                                       Margin="10,0,10,10"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Margin="5,0,0,0">
                            <TextBlock Text="Статус:"/>
                            <ComboBox x:Name="StatusComboBox"
                                      SelectedItem="{Binding Card.Статус}"
                                      IsEnabled="{Binding CanChangeStatus}">
                                <ComboBoxItem Content="Черновик"/>
                                <ComboBoxItem Content="Утверждена"/>
                            </ComboBox>
                        </StackPanel>
                    </Grid>

                    <TextBlock Text="Технология приготовления:"/>
                    <TextBox Text="{Binding Card.Технология_приготовления, UpdateSourceTrigger=PropertyChanged}"
                             Height="150"
                             TextWrapping="Wrap"
                             AcceptsReturn="True"
                             VerticalScrollBarVisibility="Auto"/>
                </StackPanel>
            </Border>
        </ScrollViewer>

        <!-- Кнопки -->
        <Border Grid.Row="1" Background="#FFEEEEEE" Padding="10">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Сохранить" 
                        Background="#FF4CAF50" 
                        Foreground="White"
                        Click="SaveButton_Click"
                        IsDefault="True"/>
                <Button Content="Отмена" 
                        Background="#FF9E9E9E" 
                        Foreground="White"
                        Click="CancelButton_Click"
                        IsCancel="True"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>