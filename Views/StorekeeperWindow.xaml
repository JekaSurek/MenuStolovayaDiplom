<Window x:Class="MenuStolovaya.Views.StorekeeperWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Меню столовой - Кладовщик" 
        Height="750" 
        Width="1400"
        MinHeight="600"
        MinWidth="1000"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="CanResizeWithGrip"
        Background="{StaticResource BackgroundBrush}">

    <Window.Resources>
        <LinearGradientBrush x:Key="HeaderGradient" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="#FF2E7D32" Offset="0"/>
            <GradientStop Color="#FF4CAF50" Offset="0.5"/>
            <GradientStop Color="#FF2E7D32" Offset="1"/>
        </LinearGradientBrush>

        <Style x:Key="WindowControlButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="35"/>
            <Setter Property="Height" Value="35"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" 
                                Background="{TemplateBinding Background}"
                                CornerRadius="17">
                            <ContentPresenter HorizontalAlignment="Center" 
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#30FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TabButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height" Value="50"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="20,0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" 
                                Background="{TemplateBinding Background}"
                                CornerRadius="0,10,10,0">
                            <ContentPresenter HorizontalAlignment="Left" 
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" 
                                        Value="{StaticResource PrimaryLightBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ActiveTabButtonStyle" TargetType="Button" BasedOn="{StaticResource TabButtonStyle}">
            <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
    </Window.Resources>

    <Border CornerRadius="15" Margin="10">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" ShadowDepth="5" Opacity="0.2"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="60"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" 
                    Background="{StaticResource HeaderGradient}"
                    CornerRadius="15,15,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" 
                                Orientation="Horizontal" 
                                VerticalAlignment="Center" 
                                Margin="20,0">
                        <Border Background="White" 
                                Width="40" 
                                Height="40" 
                                CornerRadius="20"
                                Margin="0,0,10,0">
                            <TextBlock Text="📦" 
                                       FontSize="24"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel>
                            <TextBlock Text="Меню столовой" 
                                       FontSize="18" 
                                       FontWeight="Bold" 
                                       Foreground="White"/>
                            <TextBlock Text="ООО СФ &quot;Белка-Фаворит&quot;" 
                                       FontSize="11" 
                                       Foreground="#E0E0E0"/>
                        </StackPanel>
                        <Border Background="#30FFFFFF" 
                                CornerRadius="15" 
                                Padding="10,5"
                                Margin="15,0,0,0"
                                VerticalAlignment="Center">
                            <TextBlock Text="Кладовщик" 
                                       FontSize="12" 
                                       Foreground="White"
                                       FontWeight="SemiBold"/>
                        </Border>
                    </StackPanel>

                    <StackPanel Grid.Column="1" 
            Orientation="Horizontal" 
            VerticalAlignment="Center" 
            Margin="0,0,20,0">
                        <Border Background="#30FFFFFF" 
            CornerRadius="15" 
            Padding="10,5">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="👤 " Foreground="White"/>
                                <TextBlock x:Name="CurrentUserText" 
                       FontWeight="SemiBold" 
                       Foreground="White"/>
                            </StackPanel>
                        </Border>

                        <!-- КНОПКА СВЕРНУТЬ -->
                        <Button Content="─" 
            Style="{StaticResource WindowControlButtonStyle}"
            Click="MinimizeButton_Click"
            ToolTip="Свернуть"
            Margin="10,0,0,0"/>

                        <!-- КНОПКА РАЗВЕРНУТЬ/ВОССТАНОВИТЬ -->
                        <Button x:Name="MaximizeButton" 
            Content="□" 
            Style="{StaticResource WindowControlButtonStyle}"
            Click="MaximizeButton_Click"
            ToolTip="Развернуть"
            Margin="5,0,0,0"/>

                        <Button Content="🚪" 
            Style="{StaticResource WindowControlButtonStyle}"
            Click="LogoutButton_Click"
            ToolTip="Выйти"
            Margin="5,0,0,0"/>

                        <Button Content="✕" 
            Style="{StaticResource WindowControlButtonStyle}"
            Click="CloseButton_Click"
            ToolTip="Закрыть"
            Margin="5,0,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="240"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" 
                        Background="{StaticResource CardBrush}" 
                        BorderBrush="#FFEEEEEE" 
                        BorderThickness="0,1,1,0"
                        CornerRadius="0,0,0,15">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="10,15">
                            <TextBlock Text="ДОКУМЕНТЫ" 
                                       FontSize="11" 
                                       Foreground="#FF888888"
                                       Margin="15,0,0,10"
                                       FontWeight="SemiBold"/>

                            <Button x:Name="RequestsTabButton" 
                                    Content="📋 Требования" 
                                    Style="{StaticResource TabButtonStyle}"
                                    Click="RequestsTabButton_Click"/>

                            <Button x:Name="IncomeTabButton" 
                                    Content="📥 Приход" 
                                    Style="{StaticResource TabButtonStyle}"
                                    Click="IncomeTabButton_Click"/>

                            <Button x:Name="ExpenseTabButton" 
                                    Content="📤 Расход" 
                                    Style="{StaticResource TabButtonStyle}"
                                    Click="ExpenseTabButton_Click"/>

                            <Separator Margin="15,20,15,10" Background="#FFEEEEEE"/>

                            <TextBlock Text="СПРАВОЧНИКИ" 
                                       FontSize="11" 
                                       Foreground="#FF888888"
                                       Margin="15,0,0,10"
                                       FontWeight="SemiBold"/>

                            <Button x:Name="ProductsTabButton" 
                                    Content="📦 Продукты" 
                                    Style="{StaticResource TabButtonStyle}"
                                    Click="ProductsTabButton_Click"/>

                            <Button x:Name="StocksTabButton" 
                                    Content="📊 Остатки" 
                                    Style="{StaticResource TabButtonStyle}"
                                    Click="StocksTabButton_Click"/>

                            <Separator Margin="15,20,15,10" Background="#FFEEEEEE"/>

                            <TextBlock Text="СПРАВКА" 
                                       FontSize="11" 
                                       Foreground="#FF888888"
                                       Margin="15,0,0,10"
                                       FontWeight="SemiBold"/>

                            <Button x:Name="HelpTabButton" 
                                    Content="❓ Справка" 
                                    Style="{StaticResource TabButtonStyle}"
                                    Click="HelpTabButton_Click"/>
                        </StackPanel>
                    </ScrollViewer>
                </Border>

                <Grid Grid.Column="1" Background="{StaticResource BackgroundBrush}">
                    <Grid.Resources>
                        <Style x:Key="ContentAreaStyle" TargetType="Grid">
                            <Setter Property="Margin" Value="20"/>
                        </Style>
                    </Grid.Resources>

                    <!-- Требования -->
                    <Grid x:Name="RequestsContent" Visibility="Visible" Style="{StaticResource ContentAreaStyle}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="Требования накладные" Style="{StaticResource TitleStyle}"/>

                        <Border Grid.Row="1" Style="{StaticResource CardStyle}" Margin="0,0,0,15">
                            <StackPanel Orientation="Horizontal">
                                <TextBox x:Name="RequestSearchBox" Width="300" Style="{StaticResource ModernTextBoxStyle}" TextChanged="RequestSearchBox_TextChanged" Margin="10"/>
                                <ComboBox x:Name="RequestStatusFilter" Width="150" Margin="5" SelectionChanged="RequestStatusFilter_SelectionChanged">
                                    <ComboBoxItem Content="Все статусы" IsSelected="True"/>
                                    <ComboBoxItem Content="Ожидает"/>
                                    <ComboBoxItem Content="Подтверждено"/>
                                    <ComboBoxItem Content="Отклонено"/>
                                </ComboBox>
                                <Button x:Name="ViewRequestDetailsButton" Content="📋 Просмотр" Style="{StaticResource PrimaryButtonStyle}" Click="ViewRequestDetailsButton_Click" Margin="5" IsEnabled="False"/>
                                <Button x:Name="ApproveRequestButton" Content="✓ Подтвердить" Style="{StaticResource PrimaryButtonStyle}" Background="#FF4CAF50" Click="ApproveRequestButton_Click" Margin="5" IsEnabled="False"/>
                                <Button x:Name="RejectRequestButton" Content="✗ Отклонить" Style="{StaticResource DangerButtonStyle}" Click="RejectRequestButton_Click" Margin="5" IsEnabled="False"/>
                                <Button Content="🔄 Обновить" Style="{StaticResource PrimaryButtonStyle}" Click="RefreshRequestsButton_Click" Margin="5"/>
                            </StackPanel>
                        </Border>

                        <DataGrid x:Name="RequestsDataGrid" Grid.Row="2" Style="{StaticResource ModernDataGridStyle}" AutoGenerateColumns="False" SelectionChanged="RequestsDataGrid_SelectionChanged">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Номер" Binding="{Binding Номер}" Width="120"/>
                                <DataGridTextColumn Header="Дата" Binding="{Binding Дата_документа, StringFormat={}{0:dd.MM.yyyy}}" Width="100"/>
                                <DataGridTextColumn Header="Меню от" Binding="{Binding Дата_меню, StringFormat={}{0:dd.MM.yyyy}}" Width="100"/>
                                <DataGridTextColumn Header="Технолог" Binding="{Binding Технолог}" Width="180"/>
                                <DataGridTextColumn Header="Статус" Binding="{Binding Статус_требования}" Width="100"/>
                                <DataGridTextColumn Header="Позиций" Binding="{Binding Количество_позиций}" Width="80"/>
                                <DataGridTextColumn Header="Сумма" Binding="{Binding Общая_сумма, StringFormat={}{0:N2} руб.}" Width="120"/>
                                <DataGridTextColumn Header="Кладовщик" Binding="{Binding Кладовщик}" Width="150"/>
                            </DataGrid.Columns>
                        </DataGrid>

                        <Border Grid.Row="3" Style="{StaticResource CardStyle}" Margin="0,15,0,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Всего требований: " Margin="10,0,5,0"/>
                                <TextBlock x:Name="TotalRequestsText" FontWeight="Bold" Margin="0,0,20,0"/>
                                <TextBlock Text="Ожидают: " Margin="10,0,5,0"/>
                                <TextBlock x:Name="PendingRequestsText" FontWeight="Bold" Foreground="#FF2196F3" Margin="0,0,20,0"/>
                                <TextBlock Text="Подтверждено: " Margin="10,0,5,0"/>
                                <TextBlock x:Name="ApprovedRequestsText" FontWeight="Bold" Foreground="#FF4CAF50" Margin="0,0,20,0"/>
                                <TextBlock Text="Отклонено: " Margin="10,0,5,0"/>
                                <TextBlock x:Name="RejectedRequestsText" FontWeight="Bold" Foreground="#FFF44336"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- Приход -->
                    <Grid x:Name="IncomeContent" Visibility="Collapsed" Style="{StaticResource ContentAreaStyle}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="Приход продуктов" Style="{StaticResource TitleStyle}"/>

                        <Border Grid.Row="1" Style="{StaticResource CardStyle}" Margin="0,0,0,15">
                            <StackPanel Orientation="Horizontal">
                                <Button Content="➕ Новый приход" Style="{StaticResource PrimaryButtonStyle}" Click="NewIncomeButton_Click" Margin="10,5"/>
                                <Button x:Name="EditIncomeButton" Content="✏️ Редактировать" Style="{StaticResource PrimaryButtonStyle}" Click="EditIncomeButton_Click" Margin="5" IsEnabled="False"/>
                                <Button x:Name="PostIncomeButton" Content="✓ Провести" Style="{StaticResource PrimaryButtonStyle}" Background="#FF4CAF50" Click="PostIncomeButton_Click" Margin="5" IsEnabled="False"/>
                                <Button Content="🔄 Обновить" Style="{StaticResource PrimaryButtonStyle}" Click="RefreshIncomesButton_Click" Margin="5"/>
                            </StackPanel>
                        </Border>

                        <DataGrid x:Name="IncomesDataGrid" Grid.Row="2" Style="{StaticResource ModernDataGridStyle}" AutoGenerateColumns="False" SelectionChanged="IncomesDataGrid_SelectionChanged">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Номер" Binding="{Binding Номер}" Width="120"/>
                                <DataGridTextColumn Header="Дата" Binding="{Binding Дата_документа, StringFormat={}{0:dd.MM.yyyy}}" Width="100"/>
                                <DataGridTextColumn Header="Склад" Binding="{Binding Склад_получатель}" Width="150"/>
                                <DataGridTextColumn Header="Статус" Binding="{Binding Статус}" Width="100"/>
                                <DataGridTextColumn Header="Сумма" Binding="{Binding Сумма, StringFormat={}{0:N2} руб.}" Width="120"/>
                                <DataGridTextColumn Header="Кто создал" Binding="{Binding Кто_создал}" Width="150"/>
                                <DataGridTextColumn Header="Дата создания" Binding="{Binding Дата_создания, StringFormat={}{0:dd.MM.yyyy HH:mm}}" Width="130"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>

                    <!-- Расход -->
                    <Grid x:Name="ExpenseContent" Visibility="Collapsed" Style="{StaticResource ContentAreaStyle}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="Расход продуктов" Style="{StaticResource TitleStyle}"/>

                        <Border Grid.Row="1" Style="{StaticResource CardStyle}" Margin="0,0,0,15">
                            <StackPanel Orientation="Horizontal">
                                <Button Content="➕ Новый расход" Style="{StaticResource PrimaryButtonStyle}" Click="NewExpenseButton_Click" Margin="10,5"/>
                                <Button x:Name="EditExpenseButton" Content="✏️ Редактировать" Style="{StaticResource PrimaryButtonStyle}" Click="EditExpenseButton_Click" Margin="5" IsEnabled="False"/>
                                <Button x:Name="PostExpenseButton" Content="✓ Провести" Style="{StaticResource PrimaryButtonStyle}" Background="#FF4CAF50" Click="PostExpenseButton_Click" Margin="5" IsEnabled="False"/>
                                <Button Content="🔄 Обновить" Style="{StaticResource PrimaryButtonStyle}" Click="RefreshExpensesButton_Click" Margin="5"/>
                            </StackPanel>
                        </Border>

                        <DataGrid x:Name="ExpensesDataGrid" Grid.Row="2" Style="{StaticResource ModernDataGridStyle}" AutoGenerateColumns="False" SelectionChanged="ExpensesDataGrid_SelectionChanged">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Номер" Binding="{Binding Номер}" Width="120"/>
                                <DataGridTextColumn Header="Дата" Binding="{Binding Дата_документа, StringFormat={}{0:dd.MM.yyyy}}" Width="100"/>
                                <DataGridTextColumn Header="Склад" Binding="{Binding Склад_отправитель}" Width="150"/>
                                <DataGridTextColumn Header="Статус" Binding="{Binding Статус}" Width="100"/>
                                <DataGridTextColumn Header="Сумма" Binding="{Binding Сумма, StringFormat={}{0:N2} руб.}" Width="120"/>
                                <DataGridTextColumn Header="Кто создал" Binding="{Binding Кто_создал}" Width="150"/>
                                <DataGridTextColumn Header="Дата создания" Binding="{Binding Дата_создания, StringFormat={}{0:dd.MM.yyyy HH:mm}}" Width="130"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>

                    <!-- Продукты -->
                    <Grid x:Name="ProductsContent" Visibility="Collapsed" Style="{StaticResource ContentAreaStyle}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                            <!-- Добавлена строка для статистики -->
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="Управление продуктами" Style="{StaticResource TitleStyle}"/>

                        <Border Grid.Row="1" Style="{StaticResource CardStyle}" Margin="0,0,0,15">
                            <StackPanel Orientation="Horizontal">
                                <TextBox x:Name="ProductSearchBox" Width="300" Style="{StaticResource ModernTextBoxStyle}" TextChanged="StorekeeperProductSearchBox_TextChanged" Margin="10" ToolTip="Поиск по наименованию или артикулу"/>
                                <Button Content="➕ Добавить" Style="{StaticResource PrimaryButtonStyle}" Click="StorekeeperAddProductButton_Click" Margin="5"/>
                                <Button x:Name="StorekeeperEditProductButton" Content="✏️ Редактировать" Style="{StaticResource PrimaryButtonStyle}" Click="StorekeeperEditProductButton_Click" Margin="5" IsEnabled="False"/>
                                <Button x:Name="StorekeeperDeleteProductButton" Content="🗑️ Удалить" Style="{StaticResource DangerButtonStyle}" Click="StorekeeperDeleteProductButton_Click" Margin="5" IsEnabled="False"/>
                                <Button Content="🔄 Обновить" Style="{StaticResource PrimaryButtonStyle}" Click="StorekeeperRefreshProductsButton_Click" Margin="5"/>
                            </StackPanel>
                        </Border>

                        <DataGrid x:Name="StorekeeperProductsDataGrid" Grid.Row="2" Style="{StaticResource ModernDataGridStyle}" AutoGenerateColumns="False" SelectionChanged="StorekeeperProductsDataGrid_SelectionChanged" MouseDoubleClick="StorekeeperProductsDataGrid_MouseDoubleClick">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                                <DataGridTextColumn Header="Артикул" Binding="{Binding Артикул}" Width="100"/>
                                <DataGridTextColumn Header="Наименование" Binding="{Binding Наименование}" Width="200"/>
                                <DataGridTextColumn Header="Категория" Binding="{Binding Категория}" Width="120"/>
                                <DataGridTextColumn Header="Ед. изм." Binding="{Binding Единица_измерения}" Width="80"/>
                                <DataGridTextColumn Header="Цена" Binding="{Binding Цена, StringFormat={}{0:N2} руб.}" Width="100"/>
                                <DataGridCheckBoxColumn Header="Утверждена" Binding="{Binding Утверждена_цена}" Width="80"/>
                            </DataGrid.Columns>
                        </DataGrid>

                        <!-- ДОБАВЛЕНА СТАТИСТИКА -->
                        <Border Grid.Row="3" Style="{StaticResource CardStyle}" Margin="0,15,0,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Всего продуктов: " Margin="10,0,5,0"/>
                                <TextBlock x:Name="TotalProductsText" FontWeight="Bold" Margin="0,0,20,0"/>
                                <TextBlock Text="С утвержденной ценой: " Margin="10,0,5,0"/>
                                <TextBlock x:Name="ApprovedPriceProductsText" FontWeight="Bold" Foreground="#FF4CAF50"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- Остатки -->
                    <Grid x:Name="StocksContent" Visibility="Collapsed" Style="{StaticResource ContentAreaStyle}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="Текущие остатки" Style="{StaticResource TitleStyle}"/>

                        <Border Grid.Row="1" Style="{StaticResource CardStyle}" Margin="0,0,0,15">
                            <StackPanel Orientation="Horizontal">
                                <TextBox x:Name="StockSearchBox" Width="300" Style="{StaticResource ModernTextBoxStyle}" TextChanged="StockSearchBox_TextChanged" Margin="10" ToolTip="Поиск по продукту или артикулу"/>
                                <ComboBox x:Name="WarehouseFilter" Width="200" Margin="5" SelectionChanged="WarehouseFilter_SelectionChanged"/>
                                <Button Content="🔄 Обновить" Style="{StaticResource PrimaryButtonStyle}" Click="RefreshStocksButton_Click" Margin="5"/>
                            </StackPanel>
                        </Border>

                        <DataGrid x:Name="StocksDataGrid" Grid.Row="2" Style="{StaticResource ModernDataGridStyle}" AutoGenerateColumns="False">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Склад" Binding="{Binding Склад}" Width="150"/>
                                <DataGridTextColumn Header="Артикул" Binding="{Binding Артикул}" Width="100"/>
                                <DataGridTextColumn Header="Продукт" Binding="{Binding Продукт}" Width="200"/>
                                <DataGridTextColumn Header="Категория" Binding="{Binding Категория}" Width="120"/>
                                <DataGridTextColumn Header="Ед. изм." Binding="{Binding Единица_измерения}" Width="80"/>
                                <DataGridTextColumn Header="Количество" Binding="{Binding Количество, StringFormat={}{0:F3}}" Width="100"/>
                                <DataGridTextColumn Header="Цена" Binding="{Binding Цена_за_единицу, StringFormat={}{0:N2} руб.}" Width="100"/>
                                <DataGridTextColumn Header="Сумма" Binding="{Binding Сумма, StringFormat={}{0:N2} руб.}" Width="120"/>
                            </DataGrid.Columns>
                        </DataGrid>

                        <Border Grid.Row="3" Style="{StaticResource CardStyle}" Margin="0,15,0,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Общая стоимость запасов: " Margin="10,0,5,0"/>
                                <TextBlock x:Name="TotalStockValueText" FontWeight="Bold" FontSize="16" Foreground="#FF4CAF50" Margin="0,0,20,0"/>
                                <TextBlock Text="Уникальных позиций: " Margin="10,0,5,0"/>
                                <TextBlock x:Name="UniqueProductsText" FontWeight="Bold"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- Справка -->
                    <Grid x:Name="HelpContent" Visibility="Collapsed" Style="{StaticResource ContentAreaStyle}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="Справка" Style="{StaticResource TitleStyle}"/>

                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <Border Style="{StaticResource CardStyle}" Margin="0,0,0,15">
                                    <StackPanel>
                                        <TextBlock Text="📖 О программе" Style="{StaticResource SubtitleStyle}"/>
                                        <TextBlock TextWrapping="Wrap" Margin="0,10">
                                            Система составления меню для столовой ООО СФ "Белка-Фаворит". Версия 1.0.
                                        </TextBlock>
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource CardStyle}" Margin="0,0,0,15">
                                    <StackPanel>
                                        <TextBlock Text="🎯 Обязанности кладовщика" Style="{StaticResource SubtitleStyle}"/>
                                        <TextBlock TextWrapping="Wrap" Margin="0,10">
                                            • Обработка требований накладных от технолога
                                            • Оприходование товара на склад
                                            • Списание товара со склада
                                            • Контроль текущих остатков
                                        </TextBlock>
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource CardStyle}" Margin="0,0,0,15">
                                    <StackPanel>
                                        <TextBlock Text="📞 Контакты поддержки" Style="{StaticResource SubtitleStyle}"/>
                                        <TextBlock Text="Виноградов Евгений Фёдорович" Margin="0,10,0,0"/>
                                        <TextBlock Text="📱 +7 (912) 369-87-62"/>
                                        <TextBlock Text="✉️ vinogradovfedya48@gmail.com"/>
                                    </StackPanel>
                                </Border>

                                <Button Content="📖 Открыть полную справку" Click="HelpButton_Click" Style="{StaticResource PrimaryButtonStyle}" Width="200" HorizontalAlignment="Left"/>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>