<Window x:Class="MenuStolovaya.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Столовая: Авторизация" 
        Height="400" 
        Width="600"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Style="{DynamicResource LoginWindowStyle}">

    <Window.Resources>
        <Style TargetType="TextBox">
            <Setter Property="Height" Value="35"/>
            <Setter Property="Margin" Value="10,5,10,15"/>
            <Setter Property="Padding" Value="5"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="BorderBrush" Value="#FF4CAF50"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
        </Style>

        <Style TargetType="TextBlock">
            <Setter Property="Margin" Value="10,10,10,5"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="LoginButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="40"/>
            <Setter Property="Margin" Value="10,10,10,0"/>
            <Setter Property="Background" Value="#FF4CAF50"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="Center" 
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FF45A049"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#FF3D8B40"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Background="#FF2196F3">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Левая часть с информацией -->
        <StackPanel Grid.Column="0" 
            VerticalAlignment="Center" 
            HorizontalAlignment="Center">
            <TextBlock Text="🍽️" 
               FontSize="80" 
               Margin="0,0,0,30"
               Foreground="White"/>
            <TextBlock Text="Система составления" 
               FontSize="20" 
               FontWeight="Bold" 
               HorizontalAlignment="Center"
               Foreground="White"/>
            <TextBlock Text="меню для столовой" 
               FontSize="20" 
               FontWeight="Bold" 
               HorizontalAlignment="Center"
               Margin="0,5,0,0"
               Foreground="White"/>
            <Button Content="📖 Справка" 
        Click="HelpButton_Click"
        Style="{StaticResource PrimaryButtonStyle}"
        Width="100"
        Margin="10"/>

        </StackPanel>

        <!-- Правая часть с формой входа -->
        <Border Grid.Column="1" 
                Background="White" 
                Margin="20" 
                CornerRadius="10">
            <StackPanel VerticalAlignment="Center" 
                        HorizontalAlignment="Center" 
                        Width="280">
                <TextBlock Text="Вход в систему" 
                           FontSize="24" 
                           FontWeight="Bold" 
                           HorizontalAlignment="Center" 
                           Margin="0,0,0,30" 
                           Foreground="#FF2196F3"/>

                <TextBlock Text="Логин:" 
                           Foreground="#FF333333"/>
                <TextBox x:Name="LoginTextBox"
                         TextChanged="LoginTextBox_TextChanged" Width="250"/>

                <TextBlock Text="Пароль:" 
                           Foreground="#FF333333"/>
                <PasswordBox x:Name="PasswordBox"
                             PasswordChanged="PasswordBox_PasswordChanged" Width="251"/>

                <Button Style="{StaticResource LoginButtonStyle}" 
                        HorizontalAlignment="Stretch" 
                        x:Name="ButtonLogin" 
                        Content="Войти" 
                        Click="ButtonLogin_Click"
                        IsDefault="True"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>