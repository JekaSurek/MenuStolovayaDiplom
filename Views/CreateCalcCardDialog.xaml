<Window x:Class="MenuStolovaya.Views.CreateCalcCardDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Создание калькуляционной карточки" 
        Height="550" 
        Width="700"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource BackgroundBrush}">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <TextBlock Grid.Row="0" 
                   Text="Создание новой калькуляционной карточки"
                   Style="{StaticResource SubtitleStyle}"
                   Margin="0,0,0,15"/>

        <!-- Основная форма -->
        <Border Grid.Row="1" 
                Style="{StaticResource CardStyle}">
            <Grid Margin="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Технологическая карта -->
                <TextBlock Grid.Row="0" Grid.Column="0" 
                           Text="Технологическая карта:"
                           VerticalAlignment="Center"
                           Margin="0,5"/>
                <ComboBox x:Name="TechCardCombo" 
                          Grid.Row="0" Grid.Column="1" 
                          Height="35"
                          Margin="5"
                          DisplayMemberPath="Номер"
                          SelectedValuePath="Id"/>

                <!-- Блюдо (автоматически заполняется) -->
                <TextBlock Grid.Row="1" Grid.Column="0" 
                           Text="Блюдо:"
                           VerticalAlignment="Center"
                           Margin="0,5"/>
                <TextBlock x:Name="DishText" 
                           Grid.Row="1" Grid.Column="1" 
                           VerticalAlignment="Center"
                           Margin="5"
                           FontWeight="SemiBold"/>

                <!-- Выход блюда -->
                <TextBlock Grid.Row="2" Grid.Column="0" 
                           Text="Выход блюда (г):"
                           VerticalAlignment="Center"
                           Margin="0,5"/>
                <TextBlock x:Name="OutputText" 
                           Grid.Row="2" Grid.Column="1" 
                           VerticalAlignment="Center"
                           Margin="5"
                           FontWeight="SemiBold"/>

                <!-- Процент наценки -->
                <TextBlock Grid.Row="3" Grid.Column="0" 
                           Text="Процент наценки (%):"
                           VerticalAlignment="Center"
                           Margin="0,5"/>
                <Grid Grid.Row="3" Grid.Column="1" Margin="5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Slider x:Name="MarkupSlider" 
                            Grid.Column="0"
                            Minimum="50" 
                            Maximum="300" 
                            Value="150"
                            TickFrequency="10"
                            TickPlacement="BottomRight"
                            Margin="0,0,10,0"/>
                    <TextBox x:Name="MarkupTextBox" 
                             Grid.Column="1"
                             Width="60"
                             Text="{Binding Value, ElementName=MarkupSlider, StringFormat={}{0:N0}}"
                             Style="{StaticResource ModernTextBoxStyle}"/>
                </Grid>

                <!-- Себестоимость -->
                <TextBlock Grid.Row="4" Grid.Column="0" 
                           Text="Себестоимость:"
                           VerticalAlignment="Center"
                           Margin="0,5"/>
                <TextBlock x:Name="CostText" 
                           Grid.Row="4" Grid.Column="1" 
                           VerticalAlignment="Center"
                           Margin="5"
                           FontWeight="SemiBold"
                           Foreground="#FF2196F3"/>

                <!-- Цена реализации -->
                <TextBlock Grid.Row="5" Grid.Column="0" 
                           Text="Цена реализации:"
                           VerticalAlignment="Center"
                           Margin="0,5"/>
                <TextBlock x:Name="PriceText" 
                           Grid.Row="5" Grid.Column="1" 
                           VerticalAlignment="Center"
                           Margin="5"
                           FontWeight="Bold"
                           Foreground="#FF4CAF50"/>

                <!-- Food Cost -->
                <TextBlock Grid.Row="6" Grid.Column="0" 
                           Text="Food Cost (%):"
                           VerticalAlignment="Center"
                           Margin="0,5"/>
                <TextBlock x:Name="FoodCostText" 
                           Grid.Row="6" Grid.Column="1" 
                           VerticalAlignment="Center"
                           Margin="5"
                           FontWeight="SemiBold"/>

                <!-- Маржинальность -->
                <TextBlock Grid.Row="7" Grid.Column="0" 
                           Text="Маржинальность:"
                           VerticalAlignment="Center"
                           Margin="0,5"/>
                <TextBlock x:Name="MarginText" 
                           Grid.Row="7" Grid.Column="1" 
                           VerticalAlignment="Center"
                           Margin="5"
                           FontWeight="SemiBold"/>

                <!-- Ингредиенты -->
                <TextBlock Grid.Row="8" Grid.Column="0" 
                           Text="Ингредиенты:"
                           VerticalAlignment="Top"
                           Margin="0,5"/>
                <DataGrid x:Name="IngredientsGrid" 
                          Grid.Row="8" Grid.Column="1"
                          Margin="5"
                          Height="150"
                          AutoGenerateColumns="False"
                          IsReadOnly="True">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Продукт" 
                                          Binding="{Binding Продукт}" 
                                          Width="150"/>
                        <DataGridTextColumn Header="Количество" 
                                          Binding="{Binding Количество_нетто, StringFormat={}{0:N3}}" 
                                          Width="80"/>
                        <DataGridTextColumn Header="Ед. изм." 
                                          Binding="{Binding Единица_измерения}" 
                                          Width="70"/>
                        <DataGridTextColumn Header="Цена" 
                                          Binding="{Binding Цена, StringFormat={}{0:N2} руб.}" 
                                          Width="100"/>
                        <DataGridTextColumn Header="Сумма" 
                                          Binding="{Binding Сумма, StringFormat={}{0:N2} руб.}" 
                                          Width="100"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <!-- Кнопки -->
        <Border Grid.Row="2" 
                Style="{StaticResource CardStyle}" 
                Margin="0,15,0,0">
            <StackPanel Orientation="Horizontal" 
                        HorizontalAlignment="Right">
                <Button Content="Создать" 
                        Style="{StaticResource PrimaryButtonStyle}"
                        Width="100"
                        Click="CreateButton_Click"
                        Margin="5"/>
                <Button Content="Отмена" 
                        Style="{StaticResource PrimaryButtonStyle}"
                        Background="{StaticResource AccentDarkBrush}"
                        Width="100"
                        Click="CancelButton_Click"
                        Margin="5"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>