<Window x:Class="MenuStolovaya.Views.AddEditProductWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MenuStolovaya.Views"
        mc:Ignorable="d"
        Title="{Binding WindowTitle}" 
        Height="700" 
        Width="800"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Window.Resources>
        <Style TargetType="TextBox">
            <Setter Property="Height" Value="30"/>
            <Setter Property="Margin" Value="10,5,10,10"/>
            <Setter Property="Padding" Value="5"/>
        </Style>

        <Style TargetType="TextBlock">
            <Setter Property="Margin" Value="10,10,10,5"/>
            <Setter Property="Foreground" Value="#FF333333"/>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Height" Value="30"/>
            <Setter Property="Margin" Value="10,5,10,10"/>
            <Setter Property="Padding" Value="5"/>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Height" Value="35"/>
            <Setter Property="Width" Value="100"/>
            <Setter Property="Margin" Value="10"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
            <Border Background="White" Margin="10" Padding="10">
                <StackPanel>
                    <TextBlock Text="{Binding WindowTitle}" 
                               FontSize="18" 
                               FontWeight="Bold" 
                               HorizontalAlignment="Center" 
                               Margin="0,0,0,20"/>

                    <TextBlock Text="Артикул:"/>
                    <TextBox x:Name="ArticleTextBox" 
                             Text="{Binding Product.Артикул, UpdateSourceTrigger=PropertyChanged}"/>

                    <TextBlock Text="Наименование:"/>
                    <TextBox Text="{Binding Product.Наименование, UpdateSourceTrigger=PropertyChanged}"/>

                    <TextBlock Text="Категория:"/>
                    <ComboBox x:Name="CategoryComboBox" 
                              DisplayMemberPath="Name"
                              SelectedValuePath="Id"
                              SelectedValue="{Binding Product.Категория_id}"
                              SelectionChanged="CategoryComboBox_SelectionChanged"/>

                    <TextBlock Text="Единица измерения:"/>
                    <ComboBox x:Name="UnitComboBox" 
                              ItemsSource="{Binding Units}"
                              SelectedItem="{Binding Product.Единица_измерения}"
                              SelectionChanged="UnitComboBox_SelectionChanged"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Margin="0,0,5,0">
                            <TextBlock Text="Потери холодной обработки (%):"/>
                            <TextBox x:Name="ColdLossTextBox" 
                                     Text="{Binding ColdLossText, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Margin="5,0,0,0">
                            <TextBlock Text="Потери горячей обработки (%):"/>
                            <TextBox x:Name="HotLossTextBox" 
                                     Text="{Binding HotLossText, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                    </Grid>

                    <TextBlock Text="Пищевая ценность:" FontWeight="Bold" Margin="0,10,0,5"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Margin="0,0,5,0">
                            <TextBlock Text="Белки (г/100г):"/>
                            <TextBox x:Name="ProteinsTextBox" 
                                     Text="{Binding ProteinsText, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Margin="5,0,5,0">
                            <TextBlock Text="Жиры (г/100г):"/>
                            <TextBox x:Name="FatsTextBox" 
                                     Text="{Binding FatsText, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2" Margin="5,0,5,0">
                            <TextBlock Text="Углеводы (г/100г):"/>
                            <TextBox x:Name="CarbsTextBox" 
                                     Text="{Binding CarbsText, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="3" Margin="5,0,0,0">
                            <TextBlock Text="Калорийность (ккал/100г):"/>
                            <TextBox x:Name="CalorieTextBox" 
                                     Text="{Binding CalorieText, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                    </Grid>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,20">
                        <Button Content="Рассчитать" 
                                Click="CalculateCaloriesButton_Click"
                                Background="#FF2196F3" 
                                Foreground="White"
                                Margin="0,0,10,0"/>
                    </StackPanel>
                    <TextBlock Text="💡 ВАЖНО: Все рецептуры ведутся в КИЛОГРАММАХ!" 
Foreground="#FF2196F3" 
FontSize="12" 
FontWeight="SemiBold"
Margin="10,10,10,0"/>
                    <TextBlock Text="При добавлении в рецептуру количество будет автоматически пересчитано в кг"
Foreground="#FF666666" 
FontSize="11"
Margin="10,0,10,10"/>
                    <TextBlock Text="Цена (руб.):"/>
                    
                    <TextBox x:Name="PriceTextBox" 
                             Text="{Binding PriceText, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>
            </Border>
        </ScrollViewer>

        <Border Grid.Row="1" Background="#FFEEEEEE" Padding="10">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Сохранить" 
                        Background="#FF4CAF50" 
                        Foreground="White"
                        Click="SaveButton_Click"
                        IsDefault="True"/>
                <Button Content="Отмена" 
                        Background="#FF9E9E9E" 
                        Foreground="White"
                        Click="CancelButton_Click"
                        IsCancel="True"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>