<Window x:Class="MenuStolovaya.Views.EditCalcCardDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Редактирование калькуляционной карточки" 
        Height="600" 
        Width="800"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BackgroundBrush}">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <TextBlock Grid.Row="0" 
                   Text="Редактирование калькуляционной карточки"
                   Style="{StaticResource SubtitleStyle}"
                   Margin="0,0,0,15"/>

        <!-- Основная форма -->
        <Border Grid.Row="1" 
                Style="{StaticResource CardStyle}">
            <Grid Margin="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Номер карточки -->
                <TextBlock Grid.Row="0" Grid.Column="0" 
                           Text="Номер карточки:"
                           VerticalAlignment="Center"
                           Margin="0,5"/>
                <TextBlock x:Name="CardNumberText" 
                           Grid.Row="0" Grid.Column="1" 
                           VerticalAlignment="Center"
                           Margin="5"
                           FontWeight="Bold"/>

                <!-- Блюдо -->
                <TextBlock Grid.Row="1" Grid.Column="0" 
                           Text="Блюдо:"
                           VerticalAlignment="Center"
                           Margin="0,5"/>
                <TextBlock x:Name="DishText" 
                           Grid.Row="1" Grid.Column="1" 
                           VerticalAlignment="Center"
                           Margin="5"
                           FontWeight="SemiBold"/>

                <!-- Выход блюда -->
                <TextBlock Grid.Row="2" Grid.Column="0" 
                           Text="Выход блюда (г):"
                           VerticalAlignment="Center"
                           Margin="0,5"/>
                <TextBlock x:Name="OutputText" 
                           Grid.Row="2" Grid.Column="1" 
                           VerticalAlignment="Center"
                           Margin="5"
                           FontWeight="SemiBold"/>

                <!-- Процент наценки -->
                <TextBlock Grid.Row="3" Grid.Column="0" 
                           Text="Процент наценки (%):"
                           VerticalAlignment="Center"
                           Margin="0,5"/>
                <Grid Grid.Row="3" Grid.Column="1" Margin="5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Slider x:Name="MarkupSlider" 
                            Grid.Column="0"
                            Minimum="50" 
                            Maximum="300" 
                            Value="150"
                            TickFrequency="10"
                            TickPlacement="BottomRight"
                            Margin="0,0,10,0"/>
                    <TextBox x:Name="MarkupTextBox" 
                             Grid.Column="1"
                             Width="60"
                             Text="{Binding Value, ElementName=MarkupSlider, StringFormat={}{0:N0}}"
                             Style="{StaticResource ModernTextBoxStyle}"/>
                </Grid>

                <!-- Себестоимость -->
                <TextBlock Grid.Row="4" Grid.Column="0" 
                           Text="Себестоимость:"
                           VerticalAlignment="Center"
                           Margin="0,5"/>
                <TextBlock x:Name="CostText" 
                           Grid.Row="4" Grid.Column="1" 
                           VerticalAlignment="Center"
                           Margin="5"
                           FontWeight="SemiBold"
                           Foreground="#FF2196F3"/>

                <!-- Цена реализации -->
                <TextBlock Grid.Row="5" Grid.Column="0" 
                           Text="Цена реализации:"
                           VerticalAlignment="Center"
                           Margin="0,5"/>
                <TextBlock x:Name="PriceText" 
                           Grid.Row="5" Grid.Column="1" 
                           VerticalAlignment="Center"
                           Margin="5"
                           FontWeight="Bold"
                           Foreground="#FF4CAF50"/>

                <!-- Food Cost и маржинальность -->
                <StackPanel Grid.Row="6" Grid.Column="0" 
                            VerticalAlignment="Top"
                            Margin="0,5">
                    <TextBlock Text="Food Cost (%):"/>
                    <TextBlock Text="Маржинальность:" 
                               Margin="0,10,0,0"/>
                </StackPanel>

                <StackPanel Grid.Row="6" Grid.Column="1" 
                            VerticalAlignment="Top"
                            Margin="5">
                    <TextBlock x:Name="FoodCostText" 
                               FontWeight="SemiBold"/>
                    <TextBlock x:Name="MarginText" 
                               Margin="0,10,0,0"
                               FontWeight="SemiBold"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Кнопки -->
        <Border Grid.Row="2" 
                Style="{StaticResource CardStyle}" 
                Margin="0,15,0,0">
            <StackPanel Orientation="Horizontal" 
                        HorizontalAlignment="Right">
                <Button Content="Сохранить" 
                        Style="{StaticResource PrimaryButtonStyle}"
                        Width="100"
                        Click="SaveButton_Click"
                        Margin="5"/>
                <Button Content="Отмена" 
                        Style="{StaticResource PrimaryButtonStyle}"
                        Background="{StaticResource AccentDarkBrush}"
                        Width="100"
                        Click="CancelButton_Click"
                        Margin="5"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>