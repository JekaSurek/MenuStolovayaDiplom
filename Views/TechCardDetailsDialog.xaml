<Window x:Class="MenuStolovaya.Views.TechCardDetailsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Детали технологической карты" 
        Height="600" 
        Width="900"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BackgroundBrush}" WindowState="Maximized">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <TextBlock Grid.Row="0" 
                   x:Name="TitleText"
                   Style="{StaticResource SubtitleStyle}"
                   Margin="0,0,0,15"/>

        <!-- Основная информация -->
        <Border Grid.Row="1" 
                Style="{StaticResource CardStyle}">
            <Grid Margin="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Номер карты -->
                <TextBlock Grid.Row="0" Grid.Column="0" 
                           Text="Номер карты:"
                           VerticalAlignment="Center"
                           Margin="0,5"/>
                <TextBlock x:Name="CardNumberText" 
                           Grid.Row="0" Grid.Column="1" 
                           VerticalAlignment="Center"
                           Margin="5"
                           FontWeight="Bold"/>

                <!-- Блюдо -->
                <TextBlock Grid.Row="1" Grid.Column="0" 
                           Text="Блюдо:"
                           VerticalAlignment="Center"
                           Margin="0,5"/>
                <TextBlock x:Name="DishText" 
                           Grid.Row="1" Grid.Column="1" 
                           VerticalAlignment="Center"
                           Margin="5"
                           FontWeight="SemiBold"/>

                <!-- Вид блюда -->
                <TextBlock Grid.Row="2" Grid.Column="0" 
                           Text="Вид блюда:"
                           VerticalAlignment="Center"
                           Margin="0,5"/>
                <TextBlock x:Name="DishTypeText" 
                           Grid.Row="2" Grid.Column="1" 
                           VerticalAlignment="Center"
                           Margin="5"/>

                <!-- Выход -->
                <TextBlock Grid.Row="3" Grid.Column="0" 
                           Text="Выход:"
                           VerticalAlignment="Center"
                           Margin="0,5"/>
                <TextBlock x:Name="OutputText" 
                           Grid.Row="3" Grid.Column="1" 
                           VerticalAlignment="Center"
                           Margin="5"
                           FontWeight="SemiBold"/>

                <!-- Статус -->
                <TextBlock Grid.Row="4" Grid.Column="0" 
                           Text="Статус:"
                           VerticalAlignment="Center"
                           Margin="0,5"/>
                <TextBlock x:Name="StatusText" 
                           Grid.Row="4" Grid.Column="1" 
                           VerticalAlignment="Center"
                           Margin="5"
                           FontWeight="SemiBold"/>

                <!-- Дата создания -->
                <TextBlock Grid.Row="5" Grid.Column="0" 
                           Text="Дата создания:"
                           VerticalAlignment="Center"
                           Margin="0,5"/>
                <TextBlock x:Name="CreationDateText" 
                           Grid.Row="5" Grid.Column="1" 
                           VerticalAlignment="Center"
                           Margin="5"/>
            </Grid>
        </Border>

        <!-- Технология приготовления -->
        <Border Grid.Row="2" 
                Style="{StaticResource CardStyle}" 
                Margin="0,10,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Технология приготовления:" 
                           FontWeight="SemiBold"
                           Margin="5"/>
                <ScrollViewer Grid.Row="1" 
                              VerticalScrollBarVisibility="Auto"
                              Margin="5">
                    <TextBlock x:Name="TechnologyText" 
                               TextWrapping="Wrap"/>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- Кнопки -->
        <Border Grid.Row="3" 
                Style="{StaticResource CardStyle}" 
                Margin="0,15,0,0">
            <StackPanel Orientation="Horizontal" 
                        HorizontalAlignment="Right">
                <Button Content="Печать" 
                        Style="{StaticResource PrimaryButtonStyle}"
                        Width="100"
                        Click="PrintButton_Click"
                        Margin="5"/>
                <Button Content="Закрыть" 
                        Style="{StaticResource PrimaryButtonStyle}"
                        Background="{StaticResource AccentDarkBrush}"
                        Width="100"
                        Click="CloseButton_Click"
                        Margin="5"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>