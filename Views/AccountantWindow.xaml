<Window x:Class="MenuStolovaya.Views.AccountantWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Меню столовой - Бухгалтер" 
        Height="750" 
        Width="1400"
        MinHeight="600"
        MinWidth="1000"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="CanResizeWithGrip"
        Background="{StaticResource BackgroundBrush}">

    <Window.Resources>
        <LinearGradientBrush x:Key="HeaderGradient" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="#FF2E7D32" Offset="0"/>
            <GradientStop Color="#FF4CAF50" Offset="0.5"/>
            <GradientStop Color="#FF2E7D32" Offset="1"/>
        </LinearGradientBrush>

        <Style x:Key="WindowControlButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="35"/>
            <Setter Property="Height" Value="35"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" 
                                Background="{TemplateBinding Background}"
                                CornerRadius="17">
                            <ContentPresenter HorizontalAlignment="Center" 
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#30FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TabButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height" Value="50"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="20,0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" 
                                Background="{TemplateBinding Background}"
                                CornerRadius="0,10,10,0">
                            <ContentPresenter HorizontalAlignment="Left" 
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" 
                                        Value="{StaticResource PrimaryLightBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ActiveTabButtonStyle" TargetType="Button" BasedOn="{StaticResource TabButtonStyle}">
            <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="ActionButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Width" Value="120"/>
        </Style>
    </Window.Resources>

    <Border CornerRadius="15" Margin="10">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" ShadowDepth="5" Opacity="0.2"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="60"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Верхняя панель -->
            <Border Grid.Row="0" 
                    Background="{StaticResource HeaderGradient}"
                    CornerRadius="15,15,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" 
                                Orientation="Horizontal" 
                                VerticalAlignment="Center" 
                                Margin="20,0">
                        <Border Background="White" 
                                Width="40" 
                                Height="40" 
                                CornerRadius="20"
                                Margin="0,0,10,0">
                            <TextBlock Text="🍽️" 
                                       FontSize="24"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel>
                            <TextBlock Text="Меню столовой" 
                                       FontSize="18" 
                                       FontWeight="Bold" 
                                       Foreground="White"/>
                            <TextBlock Text="ООО СФ &quot;Белка-Фаворит&quot;" 
                                       FontSize="11" 
                                       Foreground="#E0E0E0"/>
                        </StackPanel>
                        <Border Background="#30FFFFFF" 
                                CornerRadius="15" 
                                Padding="10,5"
                                Margin="15,0,0,0"
                                VerticalAlignment="Center">
                            <TextBlock Text="Бухгалтер" 
                                       FontSize="12" 
                                       Foreground="White"
                                       FontWeight="SemiBold"/>
                        </Border>
                    </StackPanel>

                    <StackPanel Grid.Column="1" 
            Orientation="Horizontal" 
            VerticalAlignment="Center" 
            Margin="0,0,20,0">
                        <Border Background="#30FFFFFF" 
            CornerRadius="15" 
            Padding="10,5">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="👤 " Foreground="White"/>
                                <TextBlock x:Name="CurrentUserText" 
                       FontWeight="SemiBold" 
                       Foreground="White"/>
                            </StackPanel>
                        </Border>

                        <!-- КНОПКА СВЕРНУТЬ -->
                        <Button Content="─" 
            Style="{StaticResource WindowControlButtonStyle}"
            Click="MinimizeButton_Click"
            ToolTip="Свернуть"
            Margin="10,0,0,0"/>

                        <!-- КНОПКА РАЗВЕРНУТЬ/ВОССТАНОВИТЬ -->
                        <Button x:Name="MaximizeButton" 
            Content="□" 
            Style="{StaticResource WindowControlButtonStyle}"
            Click="MaximizeButton_Click"
            ToolTip="Развернуть"
            Margin="5,0,0,0"/>

                        <Button Content="🚪" 
            Style="{StaticResource WindowControlButtonStyle}"
            Click="LogoutButton_Click"
            ToolTip="Выйти"
            Margin="5,0,0,0"/>

                        <Button Content="✕" 
            Style="{StaticResource WindowControlButtonStyle}"
            Click="CloseButton_Click"
            ToolTip="Закрыть"
            Margin="5,0,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Основное содержимое -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="240"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Левая панель с вкладками -->
                <Border Grid.Column="0" 
                        Background="{StaticResource CardBrush}" 
                        BorderBrush="#FFEEEEEE" 
                        BorderThickness="0,1,1,0"
                        CornerRadius="0,0,0,15">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="10,15">
                            <TextBlock Text="КАЛЬКУЛЯЦИЯ" 
                                       FontSize="11" 
                                       Foreground="#FF888888"
                                       Margin="15,0,0,10"
                                       FontWeight="SemiBold"/>

                            <Button x:Name="CalcCardsTabButton" 
                                    Content="📊 Калькуляционные карты" 
                                    Style="{StaticResource TabButtonStyle}"
                                    Click="CalcCardsTabButton_Click"/>

                            <Button x:Name="PricesTabButton" 
                                    Content="💰 Цены продуктов" 
                                    Style="{StaticResource TabButtonStyle}"
                                    Click="PricesTabButton_Click"/>

                            <Button x:Name="TechCardsTabButton" 
                                    Content="📋 Тех. карты" 
                                    Style="{StaticResource TabButtonStyle}"
                                    Click="TechCardsTabButton_Click"/>

                            <Separator Margin="15,20,15,10" Background="#FFEEEEEE"/>

                            <TextBlock Text="СПРАВКА" 
                                       FontSize="11" 
                                       Foreground="#FF888888"
                                       Margin="15,0,0,10"
                                       FontWeight="SemiBold"/>

                            <Button x:Name="HelpTabButton" 
                                    Content="❓ Справка" 
                                    Style="{StaticResource TabButtonStyle}"
                                    Click="HelpTabButton_Click"/>
                        </StackPanel>
                    </ScrollViewer>
                </Border>

                <!-- Правая панель с контентом -->
                <Grid Grid.Column="1" Background="{StaticResource BackgroundBrush}">
                    <Grid.Resources>
                        <Style x:Key="ContentAreaStyle" TargetType="Grid">
                            <Setter Property="Margin" Value="20"/>
                        </Style>
                    </Grid.Resources>

                    <!-- Калькуляционные карточки -->
                    <Grid x:Name="CalcCardsContent" 
      Visibility="Visible" 
      Style="{StaticResource ContentAreaStyle}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" 
               Text="Калькуляционные карточки" 
               Style="{StaticResource TitleStyle}"/>

                        <!-- Панель инструментов с WrapPanel для переноса кнопок -->
                        <Border Grid.Row="1" 
            Style="{StaticResource CardStyle}" 
            Margin="0,0,0,15">
                            <WrapPanel Margin="5">
                                <TextBox x:Name="CalcCardSearchBox" 
                     Width="250" 
                     Style="{StaticResource ModernTextBoxStyle}"
                     TextChanged="CalcCardSearchBox_TextChanged"
                     Margin="5"
                     ToolTip="Поиск по номеру или блюду"/>

                                <Button Content="➕ Добавить" 
                    Style="{StaticResource PrimaryButtonStyle}"
                    Click="AddCalcCardButton_Click"
                    Margin="5"
                    Height="35"/>

                                <Button x:Name="EditCalcCardButton" 
                    Content="✏️ Редактировать" 
                    Style="{StaticResource PrimaryButtonStyle}"
                    Click="EditCalcCardButton_Click"
                    Margin="5"
                    Height="35"
                    IsEnabled="False"/>

                                <Button x:Name="ApproveCalcCardButton" 
                    Content="✓ Утвердить" 
                    Style="{StaticResource PrimaryButtonStyle}"
                    Background="#FF4CAF50"
                    Click="ApproveCalcCardButton_Click"
                    Margin="5"
                    Height="35"
                    IsEnabled="False"/>

                                <!-- ВОЗВРАЩАЕМ КНОПКУ "На пересмотр" -->
                                <Button x:Name="ReturnToReviewButton" 
                    Content="🔄 На пересмотр" 
                    Style="{StaticResource WarningButtonStyle}"
                    Click="ReturnToReviewButton_Click"
                    Margin="5"
                    Height="35"
                    IsEnabled="False"
                    ToolTip="Отправить утверждённую карточку на пересмотр"/>

                                <!-- ВОЗВРАЩАЕМ КНОПКУ "В черновик" -->
                                <Button x:Name="ReturnToDraftButton" 
                    Content="📝 В черновик" 
                    Style="{StaticResource PrimaryButtonStyle}"
                    Background="#FFFF9800"
                    Click="ReturnToDraftButton_Click"
                    Margin="5"
                    Height="35"
                    IsEnabled="False"
                    ToolTip="Вернуть карточку из пересмотра в черновик"/>

                                <Button x:Name="DeleteCalcCardButton" 
                    Content="🗑️ Удалить" 
                    Style="{StaticResource DangerButtonStyle}"
                    Click="DeleteCalcCardButton_Click"
                    Margin="5"
                    Height="35"
                    IsEnabled="False"/>

                                <Button x:Name="ViewCalcLinesButton" 
                    Content="📋 Просмотр" 
                    Style="{StaticResource InfoButtonStyle}"
                    Click="ViewCalcLinesButton_Click"
                    Margin="5"
                    Height="35"
                    IsEnabled="False"/>

                                <Button Content="🔄 Обновить" 
                    Style="{StaticResource PrimaryButtonStyle}"
                    Click="RefreshCalcCardsButton_Click"
                    Margin="5"
                    Height="35"/>
                            </WrapPanel>
                        </Border>

                        <DataGrid x:Name="CalcCardsDataGrid" 
              Grid.Row="2" 
              Style="{StaticResource ModernDataGridStyle}"
              AutoGenerateColumns="False"
              SelectionChanged="CalcCardsDataGrid_SelectionChanged">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Номер" Binding="{Binding Номер}" Width="120"/>
                                <DataGridTextColumn Header="Блюдо" Binding="{Binding Блюдо}" Width="200"/>
                                <DataGridTextColumn Header="Выход (г)" Binding="{Binding Выход_порции_г}" Width="100"/>
                                <DataGridTextColumn Header="Себестоимость" Binding="{Binding Себестоимость, StringFormat={}{0:N2} руб.}" Width="120"/>
                                <DataGridTextColumn Header="Цена" Binding="{Binding Цена_реализации, StringFormat={}{0:N2} руб.}" Width="120"/>
                                <DataGridTextColumn Header="Food Cost" Binding="{Binding Фудкост_процент, StringFormat={}{0:N2}%}" Width="100"/>
                                <DataGridTextColumn Header="Наценка" Binding="{Binding Процент_наценки, StringFormat={}{0:N2}%}" Width="100"/>
                                <DataGridTextColumn Header="Статус" Binding="{Binding Статус}" Width="100"/>
                                <DataGridTextColumn Header="Дата" Binding="{Binding Дата_составления, StringFormat={}{0:dd.MM.yyyy}}" Width="100"/>
                                <DataGridTextColumn Header="Кто утвердил" Binding="{Binding Кто_утвердил}" Width="150"/>
                            </DataGrid.Columns>
                        </DataGrid>

                        <!-- Панель статистики -->
                        <Border Grid.Row="3" 
            Style="{StaticResource CardStyle}" 
            Margin="0,15,0,0">
                            <WrapPanel Margin="10,5">
                                <TextBlock Text="Всего карточек: " Margin="10,0,5,0"/>
                                <TextBlock x:Name="TotalCalcCardsText" FontWeight="Bold" Margin="0,0,20,0"/>
                                <TextBlock Text="Утверждено: " Margin="10,0,5,0"/>
                                <TextBlock x:Name="ApprovedCalcCardsText" FontWeight="Bold" Foreground="#FF4CAF50" Margin="0,0,20,0"/>
                                <TextBlock Text="На пересмотре: " Margin="10,0,5,0"/>
                                <TextBlock x:Name="ReviewCalcCardsText" FontWeight="Bold" Foreground="#FFFF9800" Margin="0,0,20,0"/>
                                <TextBlock Text="Черновиков: " Margin="10,0,5,0"/>
                                <TextBlock x:Name="DraftCalcCardsText" FontWeight="Bold" Foreground="#FF888888" Margin="0,0,20,0"/>
                                <TextBlock Text="Средний Food Cost: " Margin="10,0,5,0"/>
                                <TextBlock x:Name="AvgFoodCostText" FontWeight="Bold"/>
                            </WrapPanel>
                        </Border>
                    </Grid>

                    <!-- Цены продуктов -->
                    <Grid x:Name="PricesContent" 
                          Visibility="Collapsed" 
                          Style="{StaticResource ContentAreaStyle}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" 
                                   Text="Управление ценами продуктов" 
                                   Style="{StaticResource TitleStyle}"/>

                        <Border Grid.Row="1" 
                                Style="{StaticResource CardStyle}" 
                                Margin="0,0,0,15">
                            <StackPanel Orientation="Horizontal">
                                <TextBox x:Name="ProductPriceSearchBox" 
                                         Width="300" 
                                         Style="{StaticResource ModernTextBoxStyle}"
                                         TextChanged="ProductPriceSearchBox_TextChanged"
                                         Margin="10"
                                         ToolTip="Поиск по наименованию или артикулу"/>
                                <ComboBox x:Name="PriceStatusFilterCombo" 
                                          Width="150" 
                                          Margin="5"
                                          SelectionChanged="PriceStatusFilterCombo_SelectionChanged">
                                    <ComboBoxItem Content="Все цены" IsSelected="True"/>
                                    <ComboBoxItem Content="Утвержденные"/>
                                    <ComboBoxItem Content="На утверждении"/>
                                </ComboBox>
                                <Button x:Name="ApprovePriceButton" 
                                        Content="✓ Утвердить цену" 
                                        Style="{StaticResource PrimaryButtonStyle}"
                                        Background="#FF4CAF50"
                                        Click="ApprovePriceButton_Click"
                                        Margin="5"
                                        IsEnabled="False"/>
                                <Button x:Name="EditPriceButton" 
                                        Content="✏️ Изменить цену" 
                                        Style="{StaticResource PrimaryButtonStyle}"
                                        Background="#FFFF9800"
                                        Click="EditPriceButton_Click"
                                        Margin="5"
                                        IsEnabled="False"/>
                                <Button Content="🔄 Обновить" 
                                        Style="{StaticResource PrimaryButtonStyle}"
                                        Click="RefreshProductsButton_Click"
                                        Margin="5"/>
                            </StackPanel>
                        </Border>

                        <DataGrid x:Name="ProductsDataGrid" 
                                  Grid.Row="2" 
                                  Style="{StaticResource ModernDataGridStyle}"
                                  AutoGenerateColumns="False"
                                  SelectionChanged="ProductsDataGrid_SelectionChanged">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Артикул" Binding="{Binding Артикул}" Width="100"/>
                                <DataGridTextColumn Header="Наименование" Binding="{Binding Наименование}" Width="200"/>
                                <DataGridTextColumn Header="Категория" Binding="{Binding Категория}" Width="150"/>
                                <DataGridTextColumn Header="Ед. изм." Binding="{Binding Единица_измерения}" Width="80"/>
                                <DataGridTextColumn Header="Цена" Binding="{Binding Цена, StringFormat={}{0:N2} руб.}" Width="120"/>
                                <DataGridTextColumn Header="Статус" Binding="{Binding СтатусЦены}" Width="120">
                                    <DataGridTextColumn.CellStyle>
                                        <Style TargetType="DataGridCell">
                                            <Setter Property="HorizontalAlignment" Value="Center"/>
                                            <Setter Property="FontWeight" Value="Bold"/>
                                            <Setter Property="Foreground" Value="{Binding ЦветСтатуса}"/>
                                        </Style>
                                    </DataGridTextColumn.CellStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="Дата утверждения" Binding="{Binding Дата_утверждения_цены, StringFormat={}{0:dd.MM.yyyy}}" Width="120"/>
                                <DataGridTextColumn Header="Кто утвердил" Binding="{Binding Кто_утвердил_цену}" Width="150"/>
                            </DataGrid.Columns>
                        </DataGrid>

                        <Border Grid.Row="3" 
                                Style="{StaticResource CardStyle}" 
                                Margin="0,15,0,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Всего продуктов: " Margin="10,0,5,0"/>
                                <TextBlock x:Name="TotalProductsText" FontWeight="Bold" Margin="0,0,20,0"/>
                                <TextBlock Text="Утверждено: " Margin="10,0,5,0"/>
                                <TextBlock x:Name="ApprovedPricesText" FontWeight="Bold" Foreground="#FF4CAF50" Margin="0,0,20,0"/>
                                <TextBlock Text="На утверждении: " Margin="10,0,5,0"/>
                                <TextBlock x:Name="PendingPricesText" FontWeight="Bold" Foreground="#FFFF9800"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- Технологические карты -->
                    <Grid x:Name="TechCardsContent" 
                          Visibility="Collapsed" 
                          Style="{StaticResource ContentAreaStyle}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" 
                                   Text="Технологические карты" 
                                   Style="{StaticResource TitleStyle}"/>

                        <Border Grid.Row="1" 
                                Style="{StaticResource CardStyle}" 
                                Margin="0,0,0,15">
                            <StackPanel Orientation="Horizontal">
                                <TextBox x:Name="TechCardSearchBox" 
                                         Width="300" 
                                         Style="{StaticResource ModernTextBoxStyle}"
                                         TextChanged="TechCardSearchBox_TextChanged"
                                         Margin="10"
                                         ToolTip="Поиск по номеру или блюду"/>
                                <ComboBox x:Name="TechCardStatusCombo" 
                                          Width="150" 
                                          Margin="5"
                                          SelectionChanged="TechCardStatusCombo_SelectionChanged">
                                    <ComboBoxItem Content="Все статусы" IsSelected="True"/>
                                    <ComboBoxItem Content="Черновик"/>
                                    <ComboBoxItem Content="Утверждена"/>
                                </ComboBox>
                                <Button x:Name="ApproveTechCardButton" 
                                        Content="✓ Утвердить" 
                                        Style="{StaticResource PrimaryButtonStyle}"
                                        Background="#FF4CAF50"
                                        Click="ApproveTechCardButton_Click"
                                        Margin="5"
                                        IsEnabled="False"/>
                                <Button x:Name="ViewTechCardDetailsButton" 
                                        Content="📋 Детали" 
                                        Style="{StaticResource InfoButtonStyle}"
                                        Click="ViewTechCardDetailsButton_Click"
                                        Margin="5"
                                        IsEnabled="False"/>
                                <Button Content="🔄 Обновить" 
                                        Style="{StaticResource PrimaryButtonStyle}"
                                        Click="RefreshTechCardsButton_Click"
                                        Margin="5"/>
                            </StackPanel>
                        </Border>

                        <DataGrid x:Name="TechCardsDataGrid" 
                                  Grid.Row="2" 
                                  Style="{StaticResource ModernDataGridStyle}"
                                  AutoGenerateColumns="False"
                                  SelectionChanged="TechCardsDataGrid_SelectionChanged">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Номер" Binding="{Binding Номер}" Width="120"/>
                                <DataGridTextColumn Header="Блюдо" Binding="{Binding Блюдо}" Width="200"/>
                                <DataGridTextColumn Header="Выход (г)" Binding="{Binding Выход}" Width="100"/>
                                <DataGridTextColumn Header="Статус" Binding="{Binding Статус}" Width="100"/>
                                <DataGridTextColumn Header="Дата создания" Binding="{Binding Дата_создания, StringFormat={}{0:dd.MM.yyyy}}" Width="100"/>
                                <DataGridTextColumn Header="Ингредиентов" Binding="{Binding Количество_ингредиентов}" Width="100"/>
                                <DataGridTextColumn Header="Кто утвердил" Binding="{Binding Кто_утвердил}" Width="150"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>

                    <!-- Справка -->
                    <Grid x:Name="HelpContent" 
                          Visibility="Collapsed" 
                          Style="{StaticResource ContentAreaStyle}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" 
                                   Text="Справка" 
                                   Style="{StaticResource TitleStyle}"/>

                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <Border Style="{StaticResource CardStyle}" Margin="0,0,0,15">
                                    <StackPanel>
                                        <TextBlock Text="📖 О программе" Style="{StaticResource SubtitleStyle}"/>
                                        <TextBlock TextWrapping="Wrap" Margin="0,10">
                                            Система составления меню для столовой ООО СФ "Белка-Фаворит".
                                            Версия 1.0. Разработчик: Виноградов Евгений Фёдорович.
                                        </TextBlock>
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource CardStyle}" Margin="0,0,0,15">
                                    <StackPanel>
                                        <TextBlock Text="🎯 Обязанности бухгалтера" Style="{StaticResource SubtitleStyle}"/>
                                        <TextBlock TextWrapping="Wrap" Margin="0,10">
                                            • Утверждение технологических карт
                                            • Управление калькуляционными карточками
                                            • Контроль цен на продукты
                                            • Расчёт себестоимости и фудкоста
                                        </TextBlock>
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource CardStyle}" Margin="0,0,0,15">
                                    <StackPanel>
                                        <TextBlock Text="📞 Контакты поддержки" Style="{StaticResource SubtitleStyle}"/>
                                        <TextBlock Text="Виноградов Евгений Фёдорович" Margin="0,10,0,0"/>
                                        <TextBlock Text="📱 +7 (912) 369-87-62"/>
                                        <TextBlock Text="✉️ vinogradovfedya48@gmail.com"/>
                                    </StackPanel>
                                </Border>

                                <Button Content="📖 Открыть полную справку" 
                                        Click="HelpButton_Click"
                                        Style="{StaticResource PrimaryButtonStyle}"
                                        Width="200"
                                        HorizontalAlignment="Left"/>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>