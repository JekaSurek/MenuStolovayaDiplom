<Window x:Class="MenuStolovaya.Views.AccountantWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Меню столовой - Бухгалтер" 
        Height="750" 
        Width="1400"
        WindowStartupLocation="Manual"
        Background="{StaticResource BackgroundBrush}">

    <Window.Resources>
        <!-- Стиль зеленых вкладок как в AdminWindow -->
        <Style TargetType="TabItem">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border Name="Border" 
                                BorderThickness="1,1,1,0" 
                                BorderBrush="#FF4CAF50" 
                                CornerRadius="5,5,0,0" 
                                Margin="2,0">
                            <ContentPresenter x:Name="ContentSite"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Center"
                                              ContentSource="Header"
                                              Margin="10,5"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#FF4CAF50"/>
                                <Setter TargetName="ContentSite" Property="TextElement.Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="False">
                                <Setter TargetName="Border" Property="Background" Value="White"/>
                                <Setter TargetName="ContentSite" Property="TextElement.Foreground" Value="#FF333333"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <DockPanel>
        <!-- Заголовок с информацией о пользователе -->
        <Border DockPanel.Dock="Top" 
                Background="#FF4CAF50" 
                Height="60">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" 
                            Orientation="Horizontal" 
                            VerticalAlignment="Center" 
                            Margin="20,0">
                    <TextBlock Text="Меню столовой" 
                               FontSize="20" 
                               FontWeight="Bold" 
                               Foreground="White" 
                               VerticalAlignment="Center"/>
                    <TextBlock Text=" - Бухгалтер" 
                               FontSize="18" 
                               Foreground="White" 
                               VerticalAlignment="Center" 
                               Margin="10,0,0,0"/>
                </StackPanel>

                <StackPanel Grid.Column="1" 
                            Orientation="Horizontal" 
                            VerticalAlignment="Center" 
                            Margin="0,0,20,0">
                    <TextBlock Text="Пользователь: " 
                               Foreground="White" 
                               VerticalAlignment="Center"/>
                    <TextBlock x:Name="CurrentUserText" 
                               FontWeight="Bold" 
                               Foreground="White" 
                               VerticalAlignment="Center" 
                               Margin="5,0,20,0"/>
                    <Button Content="Выйти" 
                            Style="{StaticResource PrimaryButtonStyle}"
                            Height="35"
                            Width="80"
                            Cursor="Hand"
                            Click="LogoutButton_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Вкладки бухгалтера -->
        <TabControl Margin="10">
            <!-- Вкладка 1: Калькуляционные карточки -->
            <TabItem Header="Калькуляционные карточки">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Панель поиска и кнопок -->
                    <Border Grid.Row="0" 
                            Style="{StaticResource CardStyle}" 
                            Margin="0,0,0,10">
                        <StackPanel Grid.Row="0" 
            Orientation="Horizontal">
                            <TextBox x:Name="CalcCardSearchBox" 
             Width="300" 
             Style="{StaticResource ModernTextBoxStyle}"
             Margin="10"/>
                            <Button Content="Добавить калькуляционную карту" 
            Style="{StaticResource PrimaryButtonStyle}"
            Click="AddCalcCardButton_Click"
            Margin="5"/>
                            <Button x:Name="EditCalcCardButton" 
            Content="Редактировать" 
            Style="{StaticResource PrimaryButtonStyle}"
            Click="EditCalcCardButton_Click"
            Margin="5"
            IsEnabled="False"/>
                            <Button x:Name="ApproveCalcCardButton" 
            Content="Утвердить" 
            Style="{StaticResource PrimaryButtonStyle}"
            Background="{StaticResource PrimaryDarkBrush}"
            Click="ApproveCalcCardButton_Click"
            Margin="5"
            IsEnabled="False"/>
                            <Button x:Name="ReturnToReviewButton" 
            Content="На пересмотр" 
            Style="{StaticResource PrimaryButtonStyle}"
            Background="{StaticResource AccentBrush}"
            Click="ReturnToReviewButton_Click"
            Margin="5"
            IsEnabled="False"/>
                            <Button x:Name="ReturnToDraftButton" 
            Content="В черновик" 
            Style="{StaticResource PrimaryButtonStyle}"
            Background="{StaticResource WarningBrush}"
            Click="ReturnToDraftButton_Click"
            Margin="5"
            IsEnabled="False"/>
                            <Button x:Name="DeleteCalcCardButton" 
            Content="Удалить" 
            Style="{StaticResource PrimaryButtonStyle}"
            Background="{StaticResource DangerBrush}"
            Click="DeleteCalcCardButton_Click"
            Margin="5"
            IsEnabled="False"/>
                            <Button x:Name="ViewCalcLinesButton" 
            Content="Просмотр калькуляции" 
            Style="{StaticResource PrimaryButtonStyle}"
            Click="ViewCalcLinesButton_Click"
            Margin="5"
            IsEnabled="False"/>
                            <Button Content="Обновить" 
            Style="{StaticResource PrimaryButtonStyle}"
            Click="RefreshCalcCardsButton_Click"
            Margin="5,5,10,5"/>
                        </StackPanel>
                    </Border>

                    <!-- Список калькуляционных карточек -->
                    <DataGrid x:Name="CalcCardsDataGrid" 
                              Grid.Row="1" 
                              Style="{StaticResource ModernDataGridStyle}"
                              AutoGenerateColumns="False"
                              SelectionChanged="CalcCardsDataGrid_SelectionChanged">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Номер" 
                                                Binding="{Binding Номер}" 
                                                Width="120"/>
                            <DataGridTextColumn Header="Блюдо" 
                                                Binding="{Binding Блюдо}" 
                                                Width="200"/>
                            <DataGridTextColumn Header="Выход (г)" 
                                                Binding="{Binding Выход_порции_г}" 
                                                Width="100"/>
                            <DataGridTextColumn Header="Себестоимость" 
                                                Binding="{Binding Себестоимость, StringFormat={}{0:N2} руб.}" 
                                                Width="120"/>
                            <DataGridTextColumn Header="Цена реализации" 
                                                Binding="{Binding Цена_реализации, StringFormat={}{0:N2} руб.}" 
                                                Width="120"/>
                            <DataGridTextColumn Header="Food Cost %" 
                                                Binding="{Binding Фудкост_процент, StringFormat={}{0:N2}%}" 
                                                Width="100"/>
                            <DataGridTextColumn Header="Наценка %" 
                                                Binding="{Binding Процент_наценки, StringFormat={}{0:N2}%}" 
                                                Width="100"/>
                            <DataGridTextColumn Header="Маржинальность" 
                                                Binding="{Binding Маржинальность}" 
                                                Width="130"/>
                            <DataGridTextColumn Header="Статус" 
                                                Binding="{Binding Статус}" 
                                                Width="100"/>
                            <DataGridTextColumn Header="Дата составления" 
                                                Binding="{Binding Дата_составления, StringFormat={}{0:dd.MM.yyyy}}" 
                                                Width="120"/>
                            <DataGridTextColumn Header="Кто утвердил" 
                                                Binding="{Binding Кто_утвердил}" 
                                                Width="150"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- Панель статистики -->
                    <Border Grid.Row="2" 
                            Style="{StaticResource CardStyle}" 
                            Margin="0,10,0,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Всего карточек: " 
                                       Margin="10,0,5,0"/>
                            <TextBlock x:Name="TotalCalcCardsText" 
                                       FontWeight="Bold" 
                                       Margin="0,0,20,0"/>
                            <TextBlock Text="Утверждено: " 
                                       Margin="10,0,5,0"/>
                            <TextBlock x:Name="ApprovedCalcCardsText" 
                                       FontWeight="Bold" 
                                       Margin="0,0,20,0"/>
                            <TextBlock Text="Средний Food Cost: " 
                                       Margin="10,0,5,0"/>
                            <TextBlock x:Name="AvgFoodCostText" 
                                       FontWeight="Bold"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>

            <!-- Вкладка 2: Управление ценами продуктов -->
            <TabItem Header="Управление ценами продуктов">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Панель управления -->
                    <Border Grid.Row="0" 
                            Style="{StaticResource CardStyle}" 
                            Margin="0,0,0,10">
                        <StackPanel Orientation="Horizontal">
                            <TextBox x:Name="ProductPriceSearchBox" 
                                     Width="300" 
                                     Style="{StaticResource ModernTextBoxStyle}"
                                     Margin="10"/>
                            <ComboBox x:Name="PriceStatusFilterCombo" 
                                      Width="150" 
                                      Margin="5"
                                      SelectionChanged="PriceStatusFilterCombo_SelectionChanged">
                                <ComboBoxItem Content="Все цены"/>
                                <ComboBoxItem Content="Только утвержденные"/>
                                <ComboBoxItem Content="Только неутвержденные"/>
                            </ComboBox>
                            <Button x:Name="ApprovePriceButton" 
                                    Content="Утвердить цену" 
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Click="ApprovePriceButton_Click"
                                    Margin="5"
                                    IsEnabled="False"/>
                            <Button x:Name="EditPriceButton" 
                                    Content="Изменить цену" 
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Click="EditPriceButton_Click"
                                    Margin="5"
                                    IsEnabled="False"/>
                            <Button Content="Обновить" 
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Click="RefreshProductsButton_Click"
                                    Margin="5,5,10,5"/>
                        </StackPanel>
                    </Border>

                    <!-- Список продуктов с ценами -->
                    <DataGrid x:Name="ProductsDataGrid" 
                              Grid.Row="1" 
                              Style="{StaticResource ModernDataGridStyle}"
                              AutoGenerateColumns="False"
                              SelectionChanged="ProductsDataGrid_SelectionChanged">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Артикул" 
                                                Binding="{Binding Артикул}" 
                                                Width="100"/>
                            <DataGridTextColumn Header="Наименование" 
                                                Binding="{Binding Наименование}" 
                                                Width="200"/>
                            <DataGridTextColumn Header="Категория" 
                                                Binding="{Binding Категория}" 
                                                Width="150"/>
                            <DataGridTextColumn Header="Ед. изм." 
                                                Binding="{Binding Единица_измерения}" 
                                                Width="80"/>
                            <DataGridTextColumn Header="Текущая цена" 
                                                Binding="{Binding Цена, StringFormat={}{0:N2} руб.}" 
                                                Width="120"/>
                            <DataGridTextColumn Header="Статус цены" 
                                                Binding="{Binding СтатусЦены}" 
                                                Width="120">
                                <DataGridTextColumn.CellStyle>
                                    <Style TargetType="DataGridCell">
                                        <Setter Property="HorizontalAlignment" Value="Center"/>
                                        <Setter Property="FontWeight" Value="Bold"/>
                                        <Setter Property="Foreground" Value="{Binding ЦветСтатуса}"/>
                                    </Style>
                                </DataGridTextColumn.CellStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Дата утверждения" 
                                                Binding="{Binding Дата_утверждения_цены, StringFormat={}{0:dd.MM.yyyy}}" 
                                                Width="120"/>
                            <DataGridTextColumn Header="Кто утвердил" 
                                                Binding="{Binding Кто_утвердил_цену}" 
                                                Width="150"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- Панель статистики цен -->
                    <Border Grid.Row="2" 
                            Style="{StaticResource CardStyle}" 
                            Margin="0,10,0,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Всего продуктов: " 
                                       Margin="10,0,5,0"/>
                            <TextBlock x:Name="TotalProductsText" 
                                       FontWeight="Bold" 
                                       Margin="0,0,20,0"/>
                            <TextBlock Text="Утверждено цен: " 
                                       Margin="10,0,5,0"/>
                            <TextBlock x:Name="ApprovedPricesText" 
                                       FontWeight="Bold" 
                                       Margin="0,0,20,0"/>
                            <TextBlock Text="На утверждении: " 
                                       Margin="10,0,5,0"/>
                            <TextBlock x:Name="PendingPricesText" 
                                       FontWeight="Bold"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>

            <!-- Вкладка 3: Технологические карты -->
            <TabItem Header="Технологические карты">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Панель управления -->
                    <Border Grid.Row="0" 
                            Style="{StaticResource CardStyle}" 
                            Margin="0,0,0,10">
                        <StackPanel Orientation="Horizontal">
                            <TextBox x:Name="TechCardSearchBox" 
                                     Width="300" 
                                     Style="{StaticResource ModernTextBoxStyle}"
                                     Margin="10"/>
                            <ComboBox x:Name="TechCardStatusCombo" 
                                      Width="150" 
                                      Margin="5"
                                      SelectionChanged="TechCardStatusCombo_SelectionChanged">
                                <ComboBoxItem Content="Все статусы"/>
                                <ComboBoxItem Content="Черновик"/>
                                <ComboBoxItem Content="Утверждена"/>
                            </ComboBox>
                            <Button x:Name="ApproveTechCardButton" 
                                    Content="Утвердить техкарту" 
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Background="{StaticResource PrimaryDarkBrush}"
                                    Click="ApproveTechCardButton_Click"
                                    Margin="5"
                                    IsEnabled="False"/>
                            <Button x:Name="ViewTechCardDetailsButton" 
                                    Content="Просмотр деталей" 
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Click="ViewTechCardDetailsButton_Click"
                                    Margin="5"
                                    IsEnabled="False"/>
                            <Button Content="Обновить" 
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Click="RefreshTechCardsButton_Click"
                                    Margin="5,5,10,5"/>
                        </StackPanel>
                    </Border>

                    <!-- Список технологических карт -->
                    <DataGrid x:Name="TechCardsDataGrid" 
                              Grid.Row="1" 
                              Style="{StaticResource ModernDataGridStyle}"
                              AutoGenerateColumns="False"
                              SelectionChanged="TechCardsDataGrid_SelectionChanged">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Номер" 
                                                Binding="{Binding Номер}" 
                                                Width="120"/>
                            <DataGridTextColumn Header="Блюдо" 
                                                Binding="{Binding Блюдо}" 
                                                Width="200"/>
                            <DataGridTextColumn Header="Выход (г)" 
                                                Binding="{Binding Выход}" 
                                                Width="100"/>
                            <DataGridTextColumn Header="Статус" 
                                                Binding="{Binding Статус}" 
                                                Width="100"/>
                            <DataGridTextColumn Header="Дата создания" 
                                                Binding="{Binding Дата_создания, StringFormat={}{0:dd.MM.yyyy}}" 
                                                Width="120"/>
                            <DataGridTextColumn Header="Ингредиентов" 
                                                Binding="{Binding Количество_ингредиентов}" 
                                                Width="100"/>
                            <DataGridTextColumn Header="Кто утвердил" 
                                                Binding="{Binding Кто_утвердил}" 
                                                Width="150"/>
                            <DataGridTextColumn Header="Дата утверждения" 
                                                Binding="{Binding Дата_утверждения, StringFormat={}{0:dd.MM.yyyy}}" 
                                                Width="120"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <!-- Вкладка 4: Справка -->
            <TabItem Header="Справка">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" 
                               Text="Справка" 
                               Style="{StaticResource TitleStyle}"/>

                    <Border Grid.Row="1" 
                            Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="Обратная связь" 
                                       Style="{StaticResource SubtitleStyle}"/>

                            <StackPanel Margin="0,20,0,0">
                                <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                    <TextBlock Text="ФИО: " 
                                               FontWeight="SemiBold" 
                                               Width="150"/>
                                    <TextBlock Text="Виноградов Евгений Фёдорович"/>
                                </StackPanel>

                                <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                    <TextBlock Text="Телефон: " 
                                               FontWeight="SemiBold" 
                                               Width="150"/>
                                    <TextBlock Text="+7 (912) 369-87-62"/>
                                </StackPanel>

                                <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                    <TextBlock Text="Email: " 
                                               FontWeight="SemiBold" 
                                               Width="150"/>
                                    <TextBlock Text="vinogradovfedya48@gmail.com"/>
                                </StackPanel>
                            </StackPanel>

                            <Border Margin="0,30,0,0" 
                                    Padding="15" 
                                    Background="#FFF5F5F5" 
                                    CornerRadius="5">
                                <TextBlock Text="Для получения помощи по работе с программным обеспечением обращайтесь по указанным контактам."
                                           TextWrapping="Wrap"
                                           Foreground="#FF666666"/>
                            </Border>
                            <Button Content="📖 Справка" 
        Click="HelpButton_Click"
        Style="{StaticResource PrimaryButtonStyle}"
        Width="100"
        Margin="10"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>
        </TabControl>
    </DockPanel>
</Window>