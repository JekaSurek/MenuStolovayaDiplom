<Window x:Class="MenuStolovaya.Views.CalcLinesDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Строки калькуляции" 
        Height="500" 
        Width="900"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BackgroundBrush}">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <TextBlock Grid.Row="0" 
                   x:Name="TitleText"
                   Style="{StaticResource SubtitleStyle}"
                   Margin="0,0,0,15"/>

        <!-- Список строк калькуляции -->
        <Border Grid.Row="1" 
                Style="{StaticResource CardStyle}">
            <DataGrid x:Name="CalcLinesGrid" 
                      AutoGenerateColumns="False"
                      IsReadOnly="True">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="№" 
                                        Width="40">
                        <DataGridTextColumn.CellStyle>
                            <Style TargetType="DataGridCell">
                                <Setter Property="HorizontalAlignment" Value="Center"/>
                            </Style>
                        </DataGridTextColumn.CellStyle>
                        <DataGridTextColumn.Binding>
                            <Binding Path="RowNumber"/>
                        </DataGridTextColumn.Binding>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Продукт" 
                                        Binding="{Binding Продукт}" 
                                        Width="200"/>
                    <DataGridTextColumn Header="Ед. изм." 
                                        Binding="{Binding Единица_измерения}" 
                                        Width="80"/>
                    <DataGridTextColumn Header="Норма расхода" 
                                        Binding="{Binding Норма_расхода, StringFormat={}{0:N3}}" 
                                        Width="100"/>
                    <DataGridTextColumn Header="Цена за ед." 
                                        Binding="{Binding Цена_за_единицу, StringFormat={}{0:N2} руб.}" 
                                        Width="120"/>
                    <DataGridTextColumn Header="Сумма" 
                                        Binding="{Binding Сумма, StringFormat={}{0:N2} руб.}" 
                                        Width="120">
                        <DataGridTextColumn.CellStyle>
                            <Style TargetType="DataGridCell">
                                <Setter Property="HorizontalAlignment" Value="Right"/>
                            </Style>
                        </DataGridTextColumn.CellStyle>
                    </DataGridTextColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- Итоги -->
        <Border Grid.Row="2" 
                Style="{StaticResource CardStyle}" 
                Margin="0,10,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock x:Name="DishInfoText" 
                               FontWeight="SemiBold"/>
                    <TextBlock x:Name="OutputText" 
                               Margin="0,5,0,0"/>
                </StackPanel>

                <StackPanel Grid.Column="1" 
                            HorizontalAlignment="Right">
                    <TextBlock Text="Итого себестоимость:" 
                               HorizontalAlignment="Right"/>
                    <TextBlock x:Name="TotalCostText" 
                               FontWeight="Bold" 
                               FontSize="16"
                               Foreground="#FF2196F3"
                               HorizontalAlignment="Right"/>
                    <TextBlock Text="Цена реализации:" 
                               HorizontalAlignment="Right"
                               Margin="0,10,0,0"/>
                    <TextBlock x:Name="TotalPriceText" 
                               FontWeight="Bold" 
                               FontSize="16"
                               Foreground="#FF4CAF50"
                               HorizontalAlignment="Right"/>
                    <TextBlock x:Name="FoodCostText" 
                               HorizontalAlignment="Right"
                               Margin="0,10,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Кнопки -->
        <Border Grid.Row="3" 
                Style="{StaticResource CardStyle}" 
                Margin="0,15,0,0">
            <StackPanel Orientation="Horizontal" 
                        HorizontalAlignment="Right">
                <Button Content="Печать" 
                        Style="{StaticResource PrimaryButtonStyle}"
                        Width="100"
                        Click="PrintButton_Click"
                        Margin="5"/>
                <Button Content="Закрыть" 
                        Style="{StaticResource PrimaryButtonStyle}"
                        Background="{StaticResource AccentDarkBrush}"
                        Width="100"
                        Click="CloseButton_Click"
                        Margin="5"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>