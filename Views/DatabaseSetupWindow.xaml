<Window x:Class="MenuStolovaya.Views.DatabaseSetupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Настройка подключения к базе данных" 
        Height="600" 
        Width="600"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        ShowInTaskbar="True">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <TextBlock Grid.Row="0" 
                   Text="Настройка подключения к серверу базы данных"
                   FontSize="16" 
                   FontWeight="Bold"
                   Margin="0,0,0,15"/>

        <Separator Grid.Row="1" Margin="0,0,0,15"/>

        <!-- Сервер -->
        <TextBlock Grid.Row="2" Text="Сервер SQL:" Margin="0,5" FontWeight="SemiBold"/>
        <Grid Grid.Row="3" Margin="0,5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox x:Name="ServerTextBox" Grid.Column="0" Height="30" 
                     ToolTip="Примеры: . (локальный SQL), .\SQLEXPRESS, localhost, ИМЯ_КОМПЬЮТЕРА\ИМЯ_ЭКЗЕМПЛЯРА"/>
            <Button Grid.Column="1" 
                    Content="Подсказка" 
                    Width="80" 
                    Margin="10,0,0,0"
                    Height="30"
                    Click="BrowseServerButton_Click"/>
        </Grid>

        <!-- База данных -->
        <TextBlock Grid.Row="4" Text="Имя базы данных:" Margin="0,15,0,5" FontWeight="SemiBold"/>
        <TextBox x:Name="DatabaseTextBox" Grid.Row="5" Height="30" Margin="0,5"
                 Text="MenuStolovayaDB"/>

        <!-- Аутентификация -->
        <GroupBox Grid.Row="6" Header="Аутентификация" Margin="0,15,0,0">
            <StackPanel Margin="10">
                <RadioButton x:Name="WindowsAuthRadio" 
             Content="Windows аутентификация (текущий пользователь)" 
             IsChecked="True"
             Checked="AuthType_Changed"/>
                <RadioButton x:Name="SqlAuthRadio" 
                             Content="SQL Server аутентификация"
                             Margin="0,10,0,0"
                             Checked="AuthType_Changed"/>

                <StackPanel x:Name="SqlAuthPanel" Visibility="Collapsed" Margin="0,10,0,0">
                    <TextBlock Text="Логин:" Margin="0,5"/>
                    <TextBox x:Name="LoginTextBox" Height="30"/>
                    <TextBlock Text="Пароль:" Margin="0,10,0,5"/>
                    <PasswordBox x:Name="PasswordBox" Height="30"/>
                </StackPanel>
            </StackPanel>
        </GroupBox>

        <!-- Кнопка проверки -->
        <Button Grid.Row="7" 
                Content="Проверить подключение" 
                Width="180"
                Height="35"
                HorizontalAlignment="Left"
                Margin="0,20,0,0"
                Click="TestConnectionButton_Click"/>

        <!-- Статус -->
        <Border Grid.Row="8" 
                Background="#FFF0F0F0" 
                Padding="10" 
                Margin="0,15,0,0"
                CornerRadius="5"
                BorderBrush="#FFCCCCCC"
                BorderThickness="1">
            <TextBlock x:Name="StatusText" 
                       Text="Введите параметры подключения и нажмите 'Проверить подключение'"
                       Foreground="Gray"
                       TextWrapping="Wrap"
                       FontSize="12"/>
        </Border>

        <!-- Кнопки -->
        <StackPanel Grid.Row="10" Orientation="Horizontal" 
                    HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="📖 Справка" 
        Click="HelpButton_Click"
        Style="{StaticResource PrimaryButtonStyle}"
        Width="156"
        Margin="10"/>
            <Button Content="Сохранить" 
                    Width="100"
                    Height="35"
                    Background="#FF4CAF50"
                    Foreground="White"
                    Click="SaveButton_Click"
                    IsDefault="True"/>
            <Button Content="Отмена" 
                    Width="100"
                    Height="35"
                    Margin="10,0,0,0"
                    Click="CancelButton_Click"
                    IsCancel="True"/>
            
        </StackPanel>
    </Grid>
</Window>