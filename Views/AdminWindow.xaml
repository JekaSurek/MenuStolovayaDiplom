<Window x:Class="MenuStolovaya.Views.AdminWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Меню столовой - Администратор" 
        Height="700" 
        Width="1200"
        MinHeight="600"
        MinWidth="900"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="CanResizeWithGrip"
        Background="{StaticResource BackgroundBrush}">

    <Window.Resources>
        <LinearGradientBrush x:Key="HeaderGradient" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="#FF2E7D32" Offset="0"/>
            <GradientStop Color="#FF4CAF50" Offset="0.5"/>
            <GradientStop Color="#FF2E7D32" Offset="1"/>
        </LinearGradientBrush>

        <Style x:Key="WindowControlButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="35"/>
            <Setter Property="Height" Value="35"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" 
                                Background="{TemplateBinding Background}"
                                CornerRadius="17">
                            <ContentPresenter HorizontalAlignment="Center" 
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#30FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TabButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height" Value="50"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="20,0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" 
                                Background="{TemplateBinding Background}"
                                CornerRadius="0,10,10,0">
                            <ContentPresenter HorizontalAlignment="Left" 
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" 
                                        Value="{StaticResource PrimaryLightBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ActiveTabButtonStyle" TargetType="Button" BasedOn="{StaticResource TabButtonStyle}">
            <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
    </Window.Resources>

    <Border CornerRadius="15" Margin="10">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" ShadowDepth="5" Opacity="0.2"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="60"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" 
                    Background="{StaticResource HeaderGradient}"
                    CornerRadius="15,15,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" 
                                Orientation="Horizontal" 
                                VerticalAlignment="Center" 
                                Margin="20,0">
                        <Border Background="White" 
                                Width="40" 
                                Height="40" 
                                CornerRadius="20"
                                Margin="0,0,10,0">
                            <TextBlock Text="🍽️" 
                                       FontSize="24"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel>
                            <TextBlock Text="Меню столовой" 
                                       FontSize="18" 
                                       FontWeight="Bold" 
                                       Foreground="White"/>
                            <TextBlock Text="ООО СФ &quot;Белка-Фаворит&quot;" 
                                       FontSize="11" 
                                       Foreground="#E0E0E0"/>
                        </StackPanel>
                        <Border Background="#30FFFFFF" 
                                CornerRadius="15" 
                                Padding="10,5"
                                Margin="15,0,0,0"
                                VerticalAlignment="Center">
                            <TextBlock Text="Администратор" 
                                       FontSize="12" 
                                       Foreground="White"
                                       FontWeight="SemiBold"/>
                        </Border>
                    </StackPanel>

                    <StackPanel Grid.Column="1" 
            Orientation="Horizontal" 
            VerticalAlignment="Center" 
            Margin="0,0,20,0">
                        <Border Background="#30FFFFFF" 
            CornerRadius="15" 
            Padding="10,5">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="👤 " Foreground="White"/>
                                <TextBlock x:Name="CurrentUserText" 
                       FontWeight="SemiBold" 
                       Foreground="White"/>
                            </StackPanel>
                        </Border>

                        <!-- КНОПКА СВЕРНУТЬ -->
                        <Button Content="─" 
            Style="{StaticResource WindowControlButtonStyle}"
            Click="MinimizeButton_Click"
            ToolTip="Свернуть"
            Margin="10,0,0,0"/>

                        <!-- КНОПКА РАЗВЕРНУТЬ/ВОССТАНОВИТЬ -->
                        <Button x:Name="MaximizeButton" 
            Content="□" 
            Style="{StaticResource WindowControlButtonStyle}"
            Click="MaximizeButton_Click"
            ToolTip="Развернуть"
            Margin="5,0,0,0"/>

                        <Button Content="🚪" 
            Style="{StaticResource WindowControlButtonStyle}"
            Click="LogoutButton_Click"
            ToolTip="Выйти"
            Margin="5,0,0,0"/>

                        <Button Content="✕" 
            Style="{StaticResource WindowControlButtonStyle}"
            Click="CloseButton_Click"
            ToolTip="Закрыть"
            Margin="5,0,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="220"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" 
                        Background="{StaticResource CardBrush}" 
                        BorderBrush="#FFEEEEEE" 
                        BorderThickness="0,1,1,0"
                        CornerRadius="0,0,0,15">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="10,15">
                            <TextBlock Text="УПРАВЛЕНИЕ" 
                                       FontSize="11" 
                                       Foreground="#FF888888"
                                       Margin="15,0,0,10"
                                       FontWeight="SemiBold"/>

                            <Button x:Name="UsersTabButton" 
                                    Content="👥 Пользователи" 
                                    Style="{StaticResource TabButtonStyle}"
                                    Click="UsersTabButton_Click"/>

                            <Separator Margin="15,20,15,10" Background="#FFEEEEEE"/>

                            <TextBlock Text="СПРАВКА" 
                                       FontSize="11" 
                                       Foreground="#FF888888"
                                       Margin="15,0,0,10"
                                       FontWeight="SemiBold"/>

                            <Button x:Name="HelpTabButton" 
                                    Content="❓ Справка" 
                                    Style="{StaticResource TabButtonStyle}"
                                    Click="HelpTabButton_Click"/>
                        </StackPanel>
                    </ScrollViewer>
                </Border>

                <Grid Grid.Column="1" Background="{StaticResource BackgroundBrush}">
                    <Grid.Resources>
                        <Style x:Key="ContentAreaStyle" TargetType="Grid">
                            <Setter Property="Margin" Value="20"/>
                        </Style>
                    </Grid.Resources>

                    <Grid x:Name="UsersContent" 
                          Visibility="Visible" 
                          Style="{StaticResource ContentAreaStyle}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" 
                                   Text="Управление пользователями" 
                                   Style="{StaticResource TitleStyle}"/>

                        <Border Grid.Row="1" 
                                Style="{StaticResource CardStyle}" 
                                Margin="0,0,0,15">
                            <StackPanel Orientation="Horizontal">
                                <TextBox x:Name="SearchTextBox" 
                                         Width="300" 
                                         Style="{StaticResource ModernTextBoxStyle}"
                                         TextChanged="SearchTextBox_TextChanged"
                                         Margin="10"
                                         ToolTip="Поиск по ФИО, логину или роли"/>
                                <Button Content="➕ Добавить" 
                                        Style="{StaticResource PrimaryButtonStyle}"
                                        Background="#FF2196F3"
                                        Click="AddUserButton_Click"
                                        Margin="5"/>
                                <Button x:Name="EditUserButton" 
                                        Content="✏️ Редактировать" 
                                        Style="{StaticResource PrimaryButtonStyle}"
                                        Background="#FFFF9800"
                                        Click="EditUserButton_Click"
                                        Margin="5"
                                        IsEnabled="False"/>
                                <Button x:Name="DeleteUserButton" 
                                        Content="🗑️ Удалить" 
                                        Style="{StaticResource DangerButtonStyle}"
                                        Click="DeleteUserButton_Click"
                                        Margin="5"
                                        IsEnabled="False"/>
                                <Button Content="🔄 Обновить" 
                                        Style="{StaticResource InfoButtonStyle}"
                                        Click="RefreshButton_Click"
                                        Margin="5"/>
                            </StackPanel>
                        </Border>

                        <DataGrid x:Name="UsersDataGrid" 
                                  Grid.Row="2" 
                                  Style="{StaticResource ModernDataGridStyle}"
                                  AutoGenerateColumns="False"
                                  SelectionChanged="UsersDataGrid_SelectionChanged">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                                <DataGridTextColumn Header="Логин" Binding="{Binding Логин}" Width="120"/>
                                <DataGridTextColumn Header="ФИО" Binding="{Binding ФИО}" Width="200"/>
                                <DataGridTextColumn Header="Роль" Binding="{Binding Роль}" Width="120"/>
                                <DataGridCheckBoxColumn Header="Блокировка" Binding="{Binding Блокировка}" Width="80"/>
                                <DataGridTextColumn Header="Дата регистрации" Binding="{Binding Дата_регистрации}" Width="120"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>

                    <Grid x:Name="HelpContent" 
                          Visibility="Collapsed" 
                          Style="{StaticResource ContentAreaStyle}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" 
                                   Text="Справка" 
                                   Style="{StaticResource TitleStyle}"/>

                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <Border Style="{StaticResource CardStyle}" Margin="0,0,0,15">
                                    <StackPanel>
                                        <TextBlock Text="📖 О программе" Style="{StaticResource SubtitleStyle}"/>
                                        <TextBlock TextWrapping="Wrap" Margin="0,10">
                                            Система составления меню для столовой ООО СФ "Белка-Фаворит".
                                            Версия 1.0. Разработчик: Виноградов Евгений Фёдорович.
                                        </TextBlock>
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource CardStyle}" Margin="0,0,0,15">
                                    <StackPanel>
                                        <TextBlock Text="🎯 Основные возможности" Style="{StaticResource SubtitleStyle}"/>
                                        <TextBlock TextWrapping="Wrap" Margin="0,10">
                                            • Управление пользователями и ролями
                                            • Просмотр всех данных системы
                                            • Резервное копирование базы данных
                                        </TextBlock>
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource CardStyle}" Margin="0,0,0,15">
                                    <StackPanel>
                                        <TextBlock Text="📞 Контакты поддержки" Style="{StaticResource SubtitleStyle}"/>
                                        <TextBlock Text="Виноградов Евгений Фёдорович" Margin="0,10,0,0"/>
                                        <TextBlock Text="📱 +7 (912) 369-87-62"/>
                                        <TextBlock Text="✉️ vinogradovfedya48@gmail.com"/>
                                    </StackPanel>
                                </Border>

                                <Button Content="📖 Открыть полную справку" 
                                        Click="HelpButton_Click"
                                        Style="{StaticResource PrimaryButtonStyle}"
                                        Width="200"
                                        HorizontalAlignment="Left"/>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>