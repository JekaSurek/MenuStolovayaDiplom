<Window x:Class="MenuStolovaya.Views.AddEditMenuWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="{Binding WindowTitle}" 
        Height="600" 
        Width="800"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Window.Resources>
        <Style TargetType="TextBox">
            <Setter Property="Height" Value="30"/>
            <Setter Property="Margin" Value="10,5,10,10"/>
            <Setter Property="Padding" Value="5"/>
        </Style>

        <Style TargetType="TextBlock">
            <Setter Property="Margin" Value="10,10,10,5"/>
            <Setter Property="Foreground" Value="#FF333333"/>
        </Style>

        <Style TargetType="DatePicker">
            <Setter Property="Height" Value="30"/>
            <Setter Property="Margin" Value="10,5,10,10"/>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Height" Value="30"/>
            <Setter Property="Margin" Value="10,5,10,10"/>
            <Setter Property="Padding" Value="5"/>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Height" Value="35"/>
            <Setter Property="Width" Value="100"/>
            <Setter Property="Margin" Value="10"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Форма -->
        <Border Grid.Row="0" Background="White" Margin="10" Padding="10">
            <StackPanel>
                <TextBlock Text="{Binding WindowTitle}" 
                           FontSize="18" 
                           FontWeight="Bold" 
                           HorizontalAlignment="Center" 
                           Margin="0,0,0,20"/>

                <TextBlock Text="Дата меню:"/>
                <DatePicker x:Name="DatePicker" 
                            SelectedDate="{Binding Menu.Дата, UpdateSourceTrigger=PropertyChanged}"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,5,0">
                        <TextBlock Text="Ответственный:"/>
                        <TextBlock x:Name="ResponsibleText" 
                                   FontWeight="Bold"
                                   Margin="10,5,10,10"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="5,0,0,0">
                        <TextBlock Text="Статус:"/>
                        <ComboBox x:Name="StatusComboBox"
                                  SelectedItem="{Binding Menu.Статус}"
                                  IsEnabled="{Binding CanChangeStatus}">
                            <ComboBoxItem Content="Черновик"/>
                            <ComboBoxItem Content="Утверждено"/>
                        </ComboBox>
                    </StackPanel>
                </Grid>

                <TextBlock Text="Калорийность (общая):" 
                           Margin="0,20,0,5"/>
                <TextBox Text="{Binding Menu.Калорийность_общая, StringFormat={}{0:F0} калорий}" 
                         IsReadOnly="True"
                         Foreground="Gray"/>
            </StackPanel>
        </Border>

        <!-- Кнопки -->
        <Border Grid.Row="1" Background="#FFEEEEEE" Padding="10">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Сохранить" 
                        Background="#FF4CAF50" 
                        Foreground="White"
                        Click="SaveButton_Click"
                        IsDefault="True"/>
                <Button Content="Отмена" 
                        Background="#FF9E9E9E" 
                        Foreground="White"
                        Click="CancelButton_Click"
                        IsCancel="True"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>