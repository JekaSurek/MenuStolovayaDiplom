<Window x:Class="MenuStolovaya.Views.WarehouseDocumentDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Складской документ" 
        Height="700" 
        Width="1000"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BackgroundBrush}" WindowState="Maximized">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <TextBlock Grid.Row="0" 
                   x:Name="TitleText"
                   Style="{StaticResource SubtitleStyle}"
                   Margin="0,0,0,15"/>

        <!-- Шапка документа -->
        <Border Grid.Row="1" 
                Style="{StaticResource CardStyle}">
            <Grid Margin="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Номер:" FontWeight="SemiBold" VerticalAlignment="Center"/>
                <TextBlock Grid.Row="0" Grid.Column="1" x:Name="NumberText" VerticalAlignment="Center"/>

                <TextBlock Grid.Row="0" Grid.Column="2" Text="Дата:" FontWeight="SemiBold" VerticalAlignment="Center"/>
                <DatePicker x:Name="DatePicker" 
                            Grid.Row="0" Grid.Column="3" 
                            SelectedDate="{Binding Date, UpdateSourceTrigger=PropertyChanged}"
                            SelectedDateChanged="DatePicker_SelectedDateChanged"
                            VerticalAlignment="Center"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="Склад:" FontWeight="SemiBold" VerticalAlignment="Center"/>
                <ComboBox x:Name="WarehouseCombo" 
                          Grid.Row="1" Grid.Column="1" 
                          DisplayMemberPath="Name"
                          SelectedValuePath="Id"
                          SelectionChanged="WarehouseCombo_SelectionChanged"
                          VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- Список продуктов -->
        <Border Grid.Row="2" 
                Style="{StaticResource CardStyle}" 
                Margin="0,10,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" 
                           Text="Строки документа" 
                           FontWeight="SemiBold"
                           Margin="5,5,0,5"/>

                <!-- Панель добавления продукта -->
                <Border Grid.Row="1" 
                        Style="{StaticResource CardStyle}" 
                        Margin="5">
                    <StackPanel Orientation="Horizontal" Margin="5">
                        <TextBlock Text="Продукт:" VerticalAlignment="Center" Margin="5,0"/>
                        <ComboBox x:Name="ProductCombo" 
                                  Width="250"
                                  DisplayMemberPath="DisplayText"
                                  SelectedValuePath="Id"
                                  SelectionChanged="ProductCombo_SelectionChanged"
                                  Margin="5,0"/>
                        <TextBlock Text="Количество:" VerticalAlignment="Center" Margin="10,0,5,0"/>
                        <TextBox x:Name="QuantityTextBox" 
                                 Width="100"
                                 Style="{StaticResource ModernTextBoxStyle}"
                                 PreviewTextInput="NumberValidationTextBox"
                                 Margin="0,0,5,0"/>
                        <TextBlock x:Name="UnitText" VerticalAlignment="Center" Width="40"/>
                        <TextBlock x:Name="PriceInfoText" 
                                   VerticalAlignment="Center" 
                                   Margin="15,0,0,0"
                                   Foreground="Gray"/>
                        <Button Content="➕ Добавить" 
                                Style="{StaticResource PrimaryButtonStyle}"
                                Width="100"
                                Click="AddProductButton_Click"
                                Margin="15,0,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Таблица продуктов -->
                <DataGrid x:Name="ProductsGrid" 
                          Grid.Row="2"
                          Margin="5"
                          AutoGenerateColumns="False"
                          CanUserDeleteRows="False">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Артикул" Binding="{Binding Артикул}" Width="100"/>
                        <DataGridTextColumn Header="Продукт" Binding="{Binding Продукт}" Width="250"/>
                        <DataGridTextColumn Header="Ед. изм." Binding="{Binding Единица_измерения}" Width="80"/>
                        <DataGridTextColumn Header="Количество" Binding="{Binding Количество, StringFormat={}{0:F3}}" Width="120"/>
                        <DataGridTextColumn Header="Цена" Binding="{Binding Цена, StringFormat={}{0:N2} руб.}" Width="120"/>
                        <DataGridTextColumn Header="Сумма" Binding="{Binding Сумма, StringFormat={}{0:N2} руб.}" Width="120"/>
                        <DataGridTemplateColumn Width="60">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="✕" 
                                            Width="30" 
                                            Background="#FFF44336" 
                                            Foreground="White"
                                            Click="DeleteProductButton_Click"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- Итоговая сумма -->
                <Border Grid.Row="3" 
                        Style="{StaticResource CardStyle}" 
                        Margin="5">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <TextBlock Text="Итого сумма: " FontWeight="SemiBold" Margin="10,0,5,0"/>
                        <TextBlock x:Name="TotalSumText" 
                                   FontWeight="Bold" 
                                   FontSize="16"
                                   Foreground="#FF4CAF50"
                                   Margin="0,0,20,0"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- Кнопки -->
        <Border Grid.Row="3" 
                Style="{StaticResource CardStyle}" 
                Margin="0,15,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Сохранить" 
                        Style="{StaticResource PrimaryButtonStyle}"
                        Width="100"
                        Click="SaveButton_Click"
                        Margin="5"/>
                <Button Content="Отмена" 
                        Style="{StaticResource PrimaryButtonStyle}"
                        Background="{StaticResource AccentDarkBrush}"
                        Width="100"
                        Click="CancelButton_Click"
                        Margin="5"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>