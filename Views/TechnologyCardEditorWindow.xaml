<Window x:Class="MenuStolovaya.Views.TechnologyCardEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Редактор технологической карты" 
        Height="750" 
        Width="1200"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BackgroundBrush}">

    <Window.Resources>
        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>
    </Window.Resources>

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <Border Grid.Row="0" 
                Style="{StaticResource CardStyle}" 
                Margin="0,0,0,15">
            <StackPanel>
                <TextBlock x:Name="TitleText" 
                           Text="Редактор технологической карты"
                           Style="{StaticResource TitleStyle}"
                           Margin="0,0,0,5"/>
                <TextBlock x:Name="SubtitleText" 
                           Text=""
                           Foreground="{StaticResource TextLightBrush}"
                           FontSize="12"/>
            </StackPanel>
        </Border>

        <!-- Верхняя часть: информация о карте -->
        <Border Grid.Row="1" 
                Style="{StaticResource CardStyle}" 
                Margin="0,0,0,15">
            <Grid Margin="15">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Строка 1 -->
                <TextBlock Grid.Row="0" Grid.Column="0" 
                           Text="Номер карты:" 
                           VerticalAlignment="Center"
                           FontWeight="SemiBold"/>
                <TextBox x:Name="CardNumberTextBox" 
                         Grid.Row="0" Grid.Column="1" 
                         Style="{StaticResource ModernTextBoxStyle}"
                         IsReadOnly="True"
                         Background="#FFF0F0F0"
                         Margin="0,5,10,5"/>

                <TextBlock Grid.Row="0" Grid.Column="2" 
                           Text="Статус:" 
                           VerticalAlignment="Center"
                           FontWeight="SemiBold"/>
                <ComboBox x:Name="StatusComboBox" 
                          Grid.Row="0" Grid.Column="3" 
                          Height="35"
                          Margin="0,5,0,5"
                          IsEnabled="{Binding CanChangeStatus}">
                    <ComboBoxItem Content="Черновик"/>
                    <ComboBoxItem Content="Утверждена"/>
                </ComboBox>

                <!-- Строка 2 -->
                <TextBlock Grid.Row="1" Grid.Column="0" 
                           Text="Блюдо:" 
                           VerticalAlignment="Center"
                           FontWeight="SemiBold"/>
                <ComboBox x:Name="DishComboBox" 
                          Grid.Row="1" Grid.Column="1" 
                          Height="35"
                          DisplayMemberPath="Name"
                          SelectedValuePath="Id"
                          SelectionChanged="DishComboBox_SelectionChanged"
                          Margin="0,5,10,5"
                          IsEnabled="{Binding IsNewCard}"/>

                <TextBlock Grid.Row="1" Grid.Column="2" 
                           Text="Выход (г):" 
                           VerticalAlignment="Center"
                           FontWeight="SemiBold"/>
                <Grid Grid.Row="1" Grid.Column="3">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="OutputTextBox" 
                             Grid.Column="0"
                             Style="{StaticResource ModernTextBoxStyle}"
                             PreviewTextInput="NumberValidationTextBox"
                             Margin="0,5,5,5"/>
                    <Button x:Name="CalculateOutputButton"
                            Grid.Column="1"
                            Content="⟳ Рассчитать"
                            Width="100"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Background="{StaticResource AccentBrush}"
                            Click="CalculateOutputButton_Click"
                            Margin="0,5,0,5"
                            ToolTip="Рассчитать выход на основе рецептуры"/>
                </Grid>

                <!-- Строка 3 -->
                <TextBlock Grid.Row="2" Grid.Column="0" 
                           Text="Калорийность:" 
                           VerticalAlignment="Center"
                           FontWeight="SemiBold"/>
                <TextBlock x:Name="CaloriesText" 
                           Grid.Row="2" Grid.Column="1" 
                           VerticalAlignment="Center"
                           Foreground="{StaticResource PrimaryBrush}"
                           FontWeight="Bold"
                           Margin="0,5,10,5"/>

                <TextBlock Grid.Row="2" Grid.Column="2" 
                           Text="Время пригот.:" 
                           VerticalAlignment="Center"
                           FontWeight="SemiBold"/>
                <TextBox x:Name="CookingTimeTextBox" 
                         Grid.Row="2" Grid.Column="3" 
                         Style="{StaticResource ModernTextBoxStyle}"
                         PreviewTextInput="NumberValidationTextBox"
                         Margin="0,5,0,5"/>

                <!-- Строка 4 - Технология -->
                <TextBlock Grid.Row="3" Grid.Column="0" 
                           Text="Технология:" 
                           VerticalAlignment="Top"
                           FontWeight="SemiBold"
                           Margin="0,10,0,0"/>
                <TextBox x:Name="TechnologyTextBox" 
                         Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="3"
                         Height="80"
                         TextWrapping="Wrap"
                         AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto"
                         Style="{StaticResource ModernTextBoxStyle}"
                         Margin="0,10,0,10"/>
            </Grid>
        </Border>

        <!-- Нижняя часть: табличная часть (рецептура) -->
        <Border Grid.Row="2" 
                Style="{StaticResource CardStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Заголовок табличной части -->
                <Border Grid.Row="0" 
                        Background="{StaticResource PrimaryBrush}" 
                        Padding="10,5">
                    <TextBlock Text="Состав рецептуры (ингредиенты)" 
                               Foreground="White"
                               FontWeight="SemiBold"/>
                </Border>

                <!-- Панель добавления продукта -->
                <Border Grid.Row="1" 
                        Background="#FFF9F9F9" 
                        Padding="10"
                        BorderBrush="#FFEEEEEE"
                        BorderThickness="0,0,0,1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" 
                                   Text="Продукт:" 
                                   VerticalAlignment="Center"
                                   FontWeight="SemiBold"/>
                        <ComboBox x:Name="ProductComboBox" 
                                  Grid.Row="1" Grid.Column="0"
                                  Height="35"
                                  DisplayMemberPath="DisplayText"
                                  SelectedValuePath="Id"
                                  SelectionChanged="ProductComboBox_SelectionChanged"
                                  Margin="0,0,10,0"/>

                        <TextBlock Grid.Row="0" Grid.Column="1" 
                                   Text="Кол-во (кг):" 
                                   VerticalAlignment="Center"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Center"/>
                        <TextBox x:Name="QuantityTextBox" 
                                 Grid.Row="1" Grid.Column="1"
                                 Height="35"
                                 Text="0"
                                 PreviewTextInput="NumberValidationTextBox"
                                 Margin="0,0,10,0"/>

                        <TextBlock Grid.Row="0" Grid.Column="2" 
                                   Text="Порядок:" 
                                   VerticalAlignment="Center"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Center"/>
                        <TextBox x:Name="OrderTextBox" 
                                 Grid.Row="1" Grid.Column="2"
                                 Height="35"
                                 Text="1"
                                 PreviewTextInput="NumberValidationTextBox"
                                 Margin="0,0,10,0"/>

                        <Button x:Name="AddProductButton"
                                Grid.Row="1" Grid.Column="3"
                                Content="➕ Добавить"
                                Width="100"
                                Height="35"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Click="AddProductButton_Click"
                                Margin="5,0,0,0"/>
                    </Grid>
                </Border>

                <!-- DataGrid с рецептурой -->
                <DataGrid x:Name="RecipeDataGrid" 
                          Grid.Row="2"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          SelectionMode="Single"
                          SelectionUnit="FullRow"
                          RowHeight="35">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Порядок" 
                                            Binding="{Binding Порядок_закладки}" 
                                            Width="60">
                            <DataGridTextColumn.CellStyle>
                                <Style TargetType="DataGridCell">
                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.CellStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Артикул" 
                                            Binding="{Binding Артикул}" 
                                            Width="100"/>
                        <DataGridTextColumn Header="Продукт" 
                                            Binding="{Binding Продукт}" 
                                            Width="250"/>
                        <DataGridTextColumn Header="Ед. изм." 
                                            Binding="{Binding Единица_измерения}" 
                                            Width="80"/>
                        <DataGridTextColumn Header="Кол-во брутто (кг)" 
                                            Binding="{Binding Количество_брутто, StringFormat={}{0:F3}}" 
                                            Width="120"/>
                        <DataGridTextColumn Header="Потери холод." 
                                            Binding="{Binding Потери_холодной, StringFormat={}{0:F1}%}" 
                                            Width="100"/>
                        <DataGridTextColumn Header="Потери гор." 
                                            Binding="{Binding Потери_горячей, StringFormat={}{0:F1}%}" 
                                            Width="100"/>
                        <DataGridTextColumn Header="Кол-во нетто (кг)" 
                                            Binding="{Binding Количество_нетто, StringFormat={}{0:F3}}" 
                                            Width="120">
                            <DataGridTextColumn.CellStyle>
                                <Style TargetType="DataGridCell">
                                    <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                </Style>
                            </DataGridTextColumn.CellStyle>
                        </DataGridTextColumn>
                        <DataGridTemplateColumn Header="Действия" Width="100">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <Button Content="✏" 
                                                Width="30" 
                                                Height="28"
                                                Margin="2"
                                                Background="#FFFF9800" 
                                                Foreground="White"
                                                Click="EditRecipeButton_Click"/>
                                        <Button Content="✕" 
                                                Width="30" 
                                                Height="28"
                                                Margin="2"
                                                Background="#FFF44336" 
                                                Foreground="White"
                                                Click="DeleteRecipeButton_Click"/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- Панель управления порядком и итоги -->
                <Border Grid.Row="3" 
                        Background="#FFF9F9F9" 
                        Padding="10"
                        BorderBrush="#FFEEEEEE"
                        BorderThickness="0,1,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                            <Button Content="↑ Вверх" 
                                    Width="80"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Click="MoveUpButton_Click"
                                    Margin="0,0,5,0"/>
                            <Button Content="↓ Вниз" 
                                    Width="80"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Click="MoveDownButton_Click"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2" Orientation="Horizontal">
                            <Border Background="#FFF0F8FF" 
                                    CornerRadius="5" 
                                    Padding="10,5"
                                    Margin="0,0,15,0">
                                <TextBlock x:Name="TotalWeightText" 
                                           FontWeight="SemiBold"/>
                            </Border>
                            <Border Background="#FFF0FFF0" 
                                    CornerRadius="5" 
                                    Padding="10,5">
                                <TextBlock x:Name="TotalCaloriesText" 
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource PrimaryBrush}"/>
                            </Border>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <!-- Кнопки внизу -->
        <Border Grid.Row="3" 
                Style="{StaticResource CardStyle}" 
                Margin="0,15,0,0">
            <StackPanel Orientation="Horizontal" 
                        HorizontalAlignment="Right">
                <Button Content="💾 Сохранить" 
                        Style="{StaticResource PrimaryButtonStyle}"
                        Width="120"
                        Click="SaveButton_Click"
                        Margin="5"/>
                <Button Content="❌ Отмена" 
                        Style="{StaticResource PrimaryButtonStyle}"
                        Background="{StaticResource DangerBrush}"
                        Width="120"
                        Click="CancelButton_Click"
                        Margin="5"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>